# ==========================================
# Celeris Code - Variables de Entorno
# ==========================================
# Copia este archivo a .env y reemplaza los valores

# ------------------------------------------
# Notion API
# ------------------------------------------
# Obtén el token en: https://www.notion.so/my-integrations
NOTION_API_KEY=ntn_TU_TOKEN_AQUI

# ID de tu base de datos de leads (pipeline)
# Está en la URL de tu base de Notion (32 caracteres después del último /)
NOTION_DATABASE_ID=TU_DATABASE_ID_AQUI

# ------------------------------------------
# n8n (solo si usas self-hosted)
# ------------------------------------------
# URL de tu instancia n8n
N8N_BASE_URL=http://localhost:5678

# ------------------------------------------
# Netlify (opcional, para webhooks)
# ------------------------------------------
# Token de API de Netlify para automatizaciones
NETLIFY_API_KEY=TU_TOKEN_AQUI
NETLIFY_SITE_ID=TU_SITE_ID_AQUI

# ------------------------------------------
# WhatsApp (opcional, para notificaciones)
# ------------------------------------------
# Número de WhatsApp Business (sin +)
WHATSAPP_NUMBER=51999999999
# Mensaje pre-llenado
WHATSAPP_MESSAGE=Hola, me interesa conocer más sobre sus servicios
