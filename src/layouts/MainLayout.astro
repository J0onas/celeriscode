 ></path>
 </svg>
 </a>

 <footer class="border-t border-border-subtle bg-bg-default py-14">
 <div class="container mx-auto grid gap-12 px-6 md:grid-cols-3">
 <div>
 <h3 class="text-xl font-bold text-text-primary">{SITE_NAME}</h3>
 <p class="mt-4 max-w-sm text-sm text-text-secondary leading-relaxed">
 {SITE_DEFAULTS.description}
 </p>
 </div>

 <div>
 <h4 class="text-sm font-semibold uppercase tracking-widest text-text-secondary">Navegación</h4>
 <div class="mt-6 flex flex-col gap-3 text-sm text-text-secondary">
 <a
 href="/servicios"
 class="hover:text-primary-vibrant transition-colors"
 data-track="footer_nav_click"
 data-track-location="servicios">Servicios</a
 >
 <a
 href="/portafolio"
 class="hover:text-primary-vibrant transition-colors"
 data-track="footer_nav_click"
 data-track-location="portafolio">Portafolio</a
 >
 <a
 href="/blog"
 class="hover:text-primary-vibrant transition-colors"
 data-track="footer_nav_click"
 data-track-location="blog">Blog</a
 >
 <a
 href="/contacto"
 class="hover:text-primary-vibrant transition-colors"
 data-track="footer_nav_click"
 data-track-location="contacto">Contacto</a
 >
 </div>
 </div>

 <div>
 <h4 class="text-sm font-semibold uppercase tracking-widest text-text-secondary">Contacto</h4>
 <div class="mt-6 space-y-4 text-sm text-text-secondary">
 <p>contacto@celeriscode.com</p>
 <p class="text-text-secondary italic">Madrid, España | Remoto global</p>
 </div>
 </div>
 </div>

 <div
 class="container mx-auto mt-14 border-t border-border-subtle px-6 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-text-secondary"
 >
 <p>&copy; {new Date().getFullYear()} {SITE_NAME}. Todos los derechos reservados.</p>
 <div class="flex gap-6">
 <a href="#" class="hover:text-text-primary transition-colors">Privacidad</a>
 <a href="#" class="hover:text-text-primary transition-colors">Términos</a>
 </div>
 </div>
 </footer>

 <!-- Reveal Animation Script -->
 <script is:inline>
 (() => {
 const revealSelector = '[data-reveal]';
 const initReveal = () => {
 const elements = document.querySelectorAll(revealSelector);
 const observer = new IntersectionObserver(
 (entries) => {
 entries.forEach((entry) => {
 if (entry.isIntersecting) {
 entry.target.classList.add('is-visible');
 observer.unobserve(entry.target);
 }
 });
 },
 { threshold: 0.1 }
 );
 elements.forEach((el) => observer.observe(el));
 };
 document.addEventListener('astro:page-load', initReveal);
 initReveal();
 })();
 </script>
 </body>
</html>
