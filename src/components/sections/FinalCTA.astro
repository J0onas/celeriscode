---
import Button from '../ui/Button.astro';
import Card from '../ui/Card.astro';
import { BRAND_CTA } from '../../lib/constants';

interface Props {
 title?: string;
 subtitle?: string;
 primaryCTA?: { label: string; href: string };
 secondaryCTA?: { label: string; href: string };
 className?: string;
}

const {
 title = '¿Listo para acelerar tu <span class="gradient-text">presencia digital</span>?',
 subtitle = 'Conversemos sobre cómo podemos transformar tu negocio con una experiencia web moderna y orientada a resultados.',
 primaryCTA = { label: BRAND_CTA.primary, href: '/contacto' },
 secondaryCTA = { label: 'Explorar Servicios', href: '/servicios' },
 className = '',
} = Astro.props;
---

<section class:list={['py-20 md:py-32', className]}>
 <div class="container mx-auto px-6">
 <Card isPremium padding="lg" className="text-center max-w-5xl mx-auto overflow-hidden">
 <!-- Background decorations -->
 <div
 class="absolute -right-20 -top-20 h-64 w-64 rounded-full aurora-teal opacity-40 blur-3xl"
 >
 </div>
 <div
 class="absolute -bottom-20 -left-20 h-64 w-64 rounded-full aurora-blue opacity-30 blur-3xl"
 >
 </div>

 <div class="relative">
 <h2 class="text-3xl md:text-5xl font-extrabold text-text-primary tracking-tight">
 <Fragment set:html={title} />
 </h2>

 <p class="mt-6 text-lg md:text-xl text-text-secondary max-w-2xl mx-auto leading-relaxed">
 {subtitle}
 </p>

 <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
 <Button href={primaryCTA.href} variant="primary" size="lg" className="w-full sm:w-auto">
 {primaryCTA.label}
 </Button>
 <Button
 href={secondaryCTA.href}
 variant="secondary"
 size="lg"
 className="w-full sm:w-auto"
 >
 {secondaryCTA.label}
 </Button>
 </div>
 </div>
 </Card>
 </div>
</section>
