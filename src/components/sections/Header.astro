---
import Button from '../ui/Button.astro';
import { BRAND_CTA } from '../../lib/constants';

// Import logos
import logoDark from '../../assets/brand/logo-dark.svg?url';
import logoLight from '../../assets/brand/logo-light.svg?url';

const navLinks = [
 { href: '/servicios', label: 'Servicios' },
 { href: '/portafolio', label: 'Portafolio' },
 { href: '/blog', label: 'Blog' },
 { href: '/nosotros', label: 'Nosotros' },
];

const pathname = Astro.url.pathname;
---

<header
 id="main-header"
 class="fixed top-0 z-[100] w-full border-b border-border-subtle bg-bg-default/80 backdrop-blur-xl transition-all duration-300"
>
 <div class="container mx-auto flex h-20 md:h-24 items-center justify-between px-6 py-2">
 <a href="/" class="group inline-flex items-center gap-3 transition-transform hover:scale-[1.02]" aria-label="Volver al inicio">
 <img
 src={logoDark}
 alt="Celeris Code Logo"
 width="180"
 height="40"
 class="h-9 w-auto sm:h-10"
 data-logo-dark={logoDark}
 data-logo-light={logoLight}
 loading="eager"
 />
 </a>

 {/* Desktop Nav */}
 <nav class="hidden items-center gap-2 md:flex" aria-label="Navegación principal">
 {
 navLinks.map((link) => {
 const isActive = pathname === link.href || pathname.startsWith(`${link.href}/`);
 return (
 <a
 href={link.href}
 class:list={[
 'rounded-full px-5 py-2 text-sm font-medium transition-all relative group',
 isActive ? 'text-primary bg-primary/5' : 'text-text-secondary hover:text-primary',
 ]}
 >
 {link.label}
 {isActive && (
 <span class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-1 h-1 rounded-full bg-primary" />
 )}
 </a>
 );
 })
 }
 </nav>

 <div class="flex items-center gap-2 md:gap-4">
 <button
 type="button"
 class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-border-subtle bg-bg-card text-text-primary transition-all hover:border-primary/50 hover:text-primary hover:rotate-12 cursor-pointer outline-none"
 data-theme-toggle
 aria-label="Cambiar tema"
 >
 <svg data-icon-dark xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M21 12.79A9 9 0 1111.21 3c0 0 0 0 0 0A7 7 0 0021 12.79z"></path>
 </svg>
 <svg data-icon-light xmlns="http://www.w3.org/2000/svg" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M12 3v2m0 14v2m9-9h-2M5 12H3m15.364 6.364l-1.414-1.414M7.05 7.05 5.636 5.636m12.728 0-1.414 1.414M7.05 16.95l-1.414 1.414M12 8a4 4 0 100 8 4 4 0 000-8z"></path>
 </svg>
 </button>

 <Button
 href="/contacto"
 variant="primary"
 size="md"
 className="max-md:!hidden md:inline-flex border-beam shimmer-btn"
 >
 {BRAND_CTA.primary}
 </Button>

 {/* Mobile Toggle */}
 <button
 id="menu-toggle"
 type="button"
 class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-border-subtle bg-bg-card text-text-primary md:hidden cursor-pointer outline-none"
 aria-label="Menú"
 >
 <svg id="hamburger-icon" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
 </svg>
 <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
 </svg>
 </button>
 </div>
 </div>

 {/* Mobile Menu Dropdown (Simplified) */}
 <div
   id="mobile-menu"
   class="hidden md:hidden border-t border-border-subtle bg-bg-default/95 backdrop-blur-xl w-full shadow-2xl overflow-hidden"
 >
   <nav class="flex flex-col p-6 space-y-4">
     {navLinks.map((link) => (
       <a href={link.href} class="text-xl font-bold text-text-primary hover:text-primary py-2 border-b border-border-subtle/50 transition-colors">
         {link.label}
       </a>
     ))}
     <div class="pt-4">
       <Button href="/contacto" variant="primary" size="lg" className="w-full font-black border-beam">
         {BRAND_CTA.primary}
       </Button>
     </div>
   </nav>
 </div>
</header>

<script is:inline>
 (() => {
   const root = document.documentElement;
   const themeState = window.__ccThemeState || (window.__ccThemeState = { logos: [], buttons: [] });

   const applyTheme = (theme) => {
     root.dataset.theme = theme;
     localStorage.setItem('theme', theme);
     themeState.logos.forEach(img => { img.src = theme === 'light' ? img.dataset.logoLight : img.dataset.logoDark; });
     themeState.buttons.forEach(btn => {
       const dark = btn.querySelector('[data-icon-dark]');
       const light = btn.querySelector('[data-icon-light]');
       if (theme === 'light') { dark?.classList.add('hidden'); light?.classList.remove('hidden'); }
       else { dark?.classList.remove('hidden'); light?.classList.add('hidden'); }
     });
   };

   const setup = () => {
     const toggle = document.getElementById('menu-toggle');
     const menu = document.getElementById('mobile-menu');
     const hIcon = document.getElementById('hamburger-icon');
     const cIcon = document.getElementById('close-icon');
     const themeBtn = document.querySelector('[data-theme-toggle]');
     
     themeState.logos = Array.from(document.querySelectorAll('img[data-logo-dark]'));
     themeState.buttons = Array.from(document.querySelectorAll('[data-theme-toggle]'));

     if (toggle && menu) {
       toggle.onclick = () => {
         const isHidden = menu.classList.contains('hidden');
         if (isHidden) {
           menu.classList.remove('hidden');
           hIcon.classList.add('hidden');
           cIcon.classList.remove('hidden');
         } else {
           menu.classList.add('hidden');
           hIcon.classList.remove('hidden');
           cIcon.classList.add('hidden');
         }
       };
       menu.querySelectorAll('a').forEach(link => link.onclick = () => {
         menu.classList.add('hidden');
         hIcon.classList.remove('hidden');
         cIcon.classList.add('hidden');
       });
     }

     if (themeBtn) themeBtn.onclick = () => {
       applyTheme(root.dataset.theme === 'dark' ? 'light' : 'dark');
     };

     applyTheme(localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'));
   };

   document.addEventListener('astro:after-swap', setup);
   document.addEventListener('astro:page-load', setup);
   setup();
 })();
</script>
