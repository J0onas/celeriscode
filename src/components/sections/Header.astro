---
import Button from '../ui/Button.astro';
import { BRAND_CTA } from '../../lib/constants';

const navLinks = [
  { href: '/servicios', label: 'Servicios' },
  { href: '/portafolio', label: 'Portafolio' },
  { href: '/blog', label: 'Blog' },
  { href: '/nosotros', label: 'Nosotros' },
  { href: '/contacto', label: 'Contacto' },
];

const pathname = Astro.url.pathname;
const logoDark = '/assets/brand/logo-dark.svg';
const logoLight = '/assets/brand/logo-light.svg';
---

<header
  class="fixed top-0 z-50 w-full border-b border-white/10 bg-slate-950/80 backdrop-blur-xl transition-colors duration-220"
>
  <div class="container mx-auto flex h-20 md:h-24 items-center justify-between px-6 py-2">
    <a href="/" class="group inline-flex items-center gap-3" aria-label="Volver al inicio">
      <img
        src={logoDark}
        alt="Celeris Code Logo"
        width="180"
        height="40"
        class="h-9 w-auto sm:h-10"
        data-logo-dark={logoDark}
        data-logo-light={logoLight}
        loading="eager"
      />
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Navegación principal">
      {
        navLinks.map((link) => {
          const isActive = pathname === link.href || pathname.startsWith(`${link.href}/`);
          return (
            <a
              href={link.href}
              data-track="header_nav_click"
              data-track-location={link.href}
              class:list={[
                'rounded-full px-4 py-2 text-sm font-medium transition-colors focus-visible:ring-2 focus-visible:ring-primary-vibrant outline-none',
                isActive ? 'bg-white/10 text-white' : 'text-slate-300 hover:text-primary-vibrant',
              ]}
            >
              {link.label}
            </a>
          );
        })
      }
    </nav>

    <div class="flex items-center gap-3">
      <button
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/15 bg-white/5 text-slate-100 transition-colors hover:border-primary-vibrant/50 hover:text-primary-vibrant focus-visible:ring-2 focus-visible:ring-primary-vibrant outline-none"
        data-theme-toggle
        aria-label="Cambiar tema"
        aria-pressed="false"
      >
        <svg
          data-icon-dark
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.7"
            d="M21 12.79A9 9 0 1111.21 3c0 0 0 0 0 0A7 7 0 0021 12.79z"></path>
        </svg>
        <svg
          data-icon-light
          xmlns="http://www.w3.org/2000/svg"
          class="hidden h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.7"
            d="M12 3v2m0 14v2m9-9h-2M5 12H3m15.364 6.364l-1.414-1.414M7.05 7.05 5.636 5.636m12.728 0-1.414 1.414M7.05 16.95l-1.414 1.414M12 8a4 4 0 100 8 4 4 0 000-8z"
          ></path>
        </svg>
      </button>

      <Button
        href="/contacto"
        variant="primary"
        size="md"
        className="hidden md:inline-flex"
        data-track="header_cta_click"
        data-track-location="desktop"
      >
        {BRAND_CTA.primary}
      </Button>
    </div>
  </div>

  <!-- Mobile Nav -->
  <div class="border-t border-white/5 px-6 py-3 md:hidden">
    <div class="container mx-auto flex items-center justify-between gap-2">
      <nav
        class="flex items-center gap-2 overflow-x-auto pb-1 no-scrollbar"
        aria-label="Navegación móvil"
      >
        {
          navLinks.map((link) => {
            const isActive = pathname === link.href || pathname.startsWith(`${link.href}/`);
            return (
              <a
                href={link.href}
                data-track="header_nav_click"
                data-track-location={`${link.href}-mobile`}
                class:list={[
                  'whitespace-nowrap rounded-full px-3 py-1.5 text-xs font-semibold transition-colors',
                  isActive ? 'bg-white/10 text-white' : 'bg-white/5 text-slate-300',
                ]}
              >
                {link.label}
              </a>
            );
          })
        }
      </nav>
    </div>
  </div>
</header>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script is:inline>
  (() => {
    const root = document.documentElement;
    const getCurrentTheme = () => (root.dataset.theme === 'light' ? 'light' : 'dark');
    const themeState =
      window.__ccThemeState ||
      (window.__ccThemeState = {
        buttons: [],
        logos: [],
        listenersBound: false,
      });

    const applyTheme = (theme) => {
      root.dataset.theme = theme;
      localStorage.setItem('theme', theme);
      
      const themeColor = theme === 'light' ? '#f8fafc' : '#020617';
      let themeMeta = document.querySelector('meta[name="theme-color"]');
      if (!themeMeta) {
        themeMeta = document.createElement('meta');
        themeMeta.name = 'theme-color';
        document.head.appendChild(themeMeta);
      }
      themeMeta.setAttribute('content', themeColor);

      themeState.logos.forEach((logo) => {
        const nextSrc = theme === 'light'
          ? logo.getAttribute('data-logo-light')
          : logo.getAttribute('data-logo-dark');
        if (nextSrc) logo.setAttribute('src', nextSrc);
      });

      themeState.buttons.forEach((button) => {
        button.setAttribute('aria-pressed', String(theme === 'light'));
        const darkIcon = button.querySelector('[data-icon-dark]');
        const lightIcon = button.querySelector('[data-icon-light]');
        
        if (theme === 'light') {
          darkIcon?.classList.add('hidden');
          lightIcon?.classList.remove('hidden');
        } else {
          darkIcon?.classList.remove('hidden');
          lightIcon?.classList.add('hidden');
        }
      });
    };

    const toggleTheme = () => {
      applyTheme(getCurrentTheme() === 'dark' ? 'light' : 'dark');
    };

    const refreshThemeNodes = () => {
      themeState.logos = Array.from(
        document.querySelectorAll('img[data-logo-dark][data-logo-light]')
      ).filter((logo) => logo instanceof HTMLImageElement);

      themeState.buttons = Array.from(document.querySelectorAll('[data-theme-toggle]')).filter(
        (button) => button instanceof HTMLButtonElement
      );
    };

    const bindThemeButtons = () => {
      themeState.buttons.forEach((button) => {
        if (button.dataset.themeBound === 'true') return;
        button.dataset.themeBound = 'true';
        button.addEventListener('click', toggleTheme);
      });
    };

    const initThemeControls = () => {
      const storedTheme = localStorage.getItem('theme');
      const initialTheme =
        storedTheme === 'light' || storedTheme === 'dark' ? storedTheme : getCurrentTheme();
      refreshThemeNodes();
      applyTheme(initialTheme);
      bindThemeButtons();
    };

    const bindThemeListeners = () => {
      if (themeState.listenersBound) return;
      themeState.listenersBound = true;
      document.addEventListener('astro:after-swap', initThemeControls);
      document.addEventListener('astro:page-load', initThemeControls);
    };

    if (document.readyState === 'loading') {
      document.addEventListener(
        'DOMContentLoaded',
        () => {
          bindThemeListeners();
          initThemeControls();
        },
        { once: true }
      );
    } else {
      bindThemeListeners();
      initThemeControls();
    }
  })();
</script>
