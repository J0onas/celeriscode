---
import Button from '../ui/Button.astro';
import { BRAND_CTA } from '../../lib/constants';

// Import logos - using standard imports for SVGs
import logoDark from '../../assets/brand/logo-dark.svg?url';
import logoLight from '../../assets/brand/logo-light.svg?url';

const navLinks = [
 { href: '/servicios', label: 'Servicios' },
 { href: '/portafolio', label: 'Portafolio' },
 { href: '/blog', label: 'Blog' },
 { href: '/nosotros', label: 'Nosotros' },
];

const pathname = Astro.url.pathname;
---

<header
 class="fixed top-0 z-50 w-full border-b border-border-subtle bg-bg-default/80 backdrop-blur-xl transition-all duration-300"
>
 <div class="container mx-auto flex h-20 md:h-24 items-center justify-between px-6 py-2">
 <a href="/" class="group inline-flex items-center gap-3 transition-transform hover:scale-[1.02]" aria-label="Volver al inicio">
 <img
 src={logoDark}
 alt="Celeris Code Logo"
 width="180"
 height="40"
 class="h-9 w-auto sm:h-10"
 data-logo-dark={logoDark}
 data-logo-light={logoLight}
 loading="eager"
 />
 </a>

 <nav class="hidden items-center gap-2 md:flex" aria-label="Navegación principal">
 {
 navLinks.map((link) => {
 const isActive = pathname === link.href || pathname.startsWith(`${link.href}/`);
 return (
 <a
 href={link.href}
 class:list={[
 'rounded-full px-5 py-2 text-sm font-medium transition-all relative group',
 isActive ? 'text-primary bg-primary/5' : 'text-text-secondary hover:text-primary',
 ]}
 >
 {link.label}
 {isActive && (
 <span class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-1 h-1 rounded-full bg-primary" />
 )}
 </a>
 );
 })
 }
 </nav>

 <div class="flex items-center gap-4">
 <button
 type="button"
 class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-border-subtle bg-bg-card text-text-primary transition-all hover:border-primary/50 hover:text-primary hover:rotate-12 cursor-pointer outline-none"
 data-theme-toggle
 aria-label="Cambiar tema"
 >
 <svg data-icon-dark xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M21 12.79A9 9 0 1111.21 3c0 0 0 0 0 0A7 7 0 0021 12.79z"></path>
 </svg>
 <svg data-icon-light xmlns="http://www.w3.org/2000/svg" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M12 3v2m0 14v2m9-9h-2M5 12H3m15.364 6.364l-1.414-1.414M7.05 7.05 5.636 5.636m12.728 0-1.414 1.414M7.05 16.95l-1.414 1.414M12 8a4 4 0 100 8 4 4 0 000-8z"></path>
 </svg>
 </button>

 <Button
 href="/contacto"
 variant="primary"
 size="md"
 className="hidden md:inline-flex hover-lift shadow-lg shadow-primary/20 font-bold"
 >
 {BRAND_CTA.primary}
 </Button>
 </div>
 </div>

 <!-- Mobile Nav -->
 <div class="border-t border-border-subtle px-6 py-3 md:hidden">
 <nav class="flex items-center gap-2 overflow-x-auto no-scrollbar" aria-label="Navegación móvil">
 {
 [...navLinks, { href: '/contacto', label: 'Contacto' }].map((link) => {
 const isActive = pathname === link.href || pathname.startsWith(`${link.href}/`);
 return (
 <a
 href={link.href}
 class:list={[
 'whitespace-nowrap rounded-full px-4 py-2 text-xs font-bold transition-all',
 isActive ? 'bg-primary text-white' : 'bg-bg-card border border-border-subtle text-text-secondary',
 ]}
 >
 {link.label}
 </a>
 );
 })
 }
 </nav>
 </div>
</header>

<style>
 .no-scrollbar::-webkit-scrollbar { display: none; }
 .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script is:inline>
 (() => {
 const root = document.documentElement;
 const getCurrentTheme = () => (root.dataset.theme === 'light' ? 'light' : 'dark');
 const themeState = window.__ccThemeState || (window.__ccThemeState = { buttons: [], logos: [], listenersBound: false });

 const applyTheme = (theme) => {
 root.dataset.theme = theme;
 localStorage.setItem('theme', theme);
 const themeColor = theme === 'light' ? '#f8fafc' : '#020617';
 let themeMeta = document.querySelector('meta[name="theme-color"]') || document.createElement('meta');
 themeMeta.name = 'theme-color';
 themeMeta.setAttribute('content', themeColor);
 document.head.appendChild(themeMeta);

 themeState.logos.forEach((logo) => {
 const nextSrc = theme === 'light' ? logo.getAttribute('data-logo-light') : logo.getAttribute('data-logo-dark');
 if (nextSrc) logo.setAttribute('src', nextSrc);
 });

 themeState.buttons.forEach((button) => {
 const darkIcon = button.querySelector('[data-icon-dark]');
 const lightIcon = button.querySelector('[data-icon-light]');
 if (theme === 'light') { darkIcon?.classList.add('hidden'); lightIcon?.classList.remove('hidden'); }
 else { darkIcon?.classList.remove('hidden'); lightIcon?.classList.add('hidden'); }
 });
 };

 const toggleTheme = () => applyTheme(getCurrentTheme() === 'dark' ? 'light' : 'dark');
 const refreshThemeNodes = () => {
 themeState.logos = Array.from(document.querySelectorAll('img[data-logo-dark]'));
 themeState.buttons = Array.from(document.querySelectorAll('[data-theme-toggle]'));
 };
 const bindThemeButtons = () => themeState.buttons.forEach(btn => {
 if (btn.dataset.themeBound) return;
 btn.dataset.themeBound = "true";
 btn.addEventListener('click', toggleTheme);
 });
 const initThemeControls = () => { refreshThemeNodes(); applyTheme(localStorage.getItem('theme') || getCurrentTheme()); bindThemeButtons(); };

 if (!themeState.listenersBound) {
 themeState.listenersBound = true;
 document.addEventListener('astro:after-swap', initThemeControls);
 document.addEventListener('astro:page-load', initThemeControls);
 }
 initThemeControls();
 })();
</script>
