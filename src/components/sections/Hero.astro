---
import Button from '../ui/Button.astro';
import { BRAND_CTA } from '../../lib/constants';

interface Props {
  title?: string;
  subtitle?: string;
  badge?: string;
  primaryCTA?: { label: string; href: string };
  secondaryCTA?: { label: string; href: string };
  showBento?: boolean;
}

const {
  title = 'Construimos productos digitales <span class="gradient-text block">modernos, rápidos y rentables</span>',
  subtitle = 'Ayudamos a marcas y negocios a escalar con experiencias web minimalistas: landing pages de alto impacto, sitios multipage, ecommerce y plataformas SaaS.',
  badge = 'Diseño UI/UX + Desarrollo web orientado a conversión',
  primaryCTA = { label: BRAND_CTA.primary, href: '/contacto' },
  secondaryCTA = { label: BRAND_CTA.secondary, href: '/portafolio' },
  showBento = false,
} = Astro.props;

const services = ['Landing Page', 'Multipage', 'Ecommerce', 'SaaS'];
---

<section id="hero" class="relative overflow-hidden pb-20 pt-32 md:pt-40">
  <!-- Background Decorations -->
  <div class="pointer-events-none absolute inset-0 -z-20">
    <div class="aurora-blue absolute -left-[10%] top-[-10%] h-72 w-72 opacity-60"></div>
    <div class="aurora-purple absolute right-[-8%] top-[12%] h-72 w-72 opacity-50"></div>
    <div class="aurora-teal absolute bottom-[-12%] left-1/2 h-80 w-80 -translate-x-1/2 opacity-40">
    </div>
  </div>

  <div class="container mx-auto px-6">
    <div class="mx-auto max-w-4xl text-center">
      {
        badge && (
          <span class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[11px] font-bold uppercase tracking-wider text-slate-300 mb-6">
            {badge}
          </span>
        )
      }

      <h1 class="text-4xl md:text-7xl font-black leading-[0.95] text-white tracking-tight">
        <Fragment set:html={title} />
      </h1>

      <p class="mx-auto mt-8 max-w-2xl text-base md:text-xl leading-relaxed text-slate-300">
        {subtitle}
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href={primaryCTA.href} variant="primary" size="lg" className="w-full sm:w-auto">
          {primaryCTA.label}
        </Button>
        <Button href={secondaryCTA.href} variant="secondary" size="lg" className="w-full sm:w-auto">
          {secondaryCTA.label}
        </Button>
      </div>

      <div class="mt-12 flex flex-wrap items-center justify-center gap-2">
        {
          services.map((service) => (
            <span class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-slate-300">
              {service}
            </span>
          ))
        }
      </div>
    </div>

    {
      showBento && (
        <div class="mx-auto mt-16 grid max-w-6xl grid-cols-1 gap-5 md:grid-cols-12">
          <article class="relative overflow-hidden rounded-3xl border border-white/12 bg-white/5 p-8 md:col-span-7 backdrop-blur-xl">
            <p class="font-mono text-[10px] uppercase tracking-widest text-primary-vibrant">
              Proyecto destacado
            </p>
            <h2 class="mt-3 text-2xl font-extrabold text-white">POSmart SaaS</h2>
            <p class="mt-3 max-w-xl text-slate-300 leading-relaxed">
              Plataforma para gestión comercial con foco en operación diaria: facturación,
              inventario y reportes en tiempo real.
            </p>
            <div class="mt-6 flex flex-wrap gap-2">
              <span class="rounded-full border border-white/10 bg-white/5 px-2 py-1 text-[10px] font-bold uppercase text-slate-300">
                Retail
              </span>
              <span class="rounded-full border border-white/10 bg-white/5 px-2 py-1 text-[10px] font-bold uppercase text-slate-300">
                SaaS
              </span>
            </div>
            <Button
              href="https://posmart-app.vercel.app/login"
              variant="outline"
              size="sm"
              className="mt-8"
              target="_blank"
              rel="noopener noreferrer"
            >
              Abrir proyecto
            </Button>
          </article>

          <article class="relative overflow-hidden rounded-3xl border border-white/12 bg-white/5 p-8 md:col-span-5 backdrop-blur-xl">
            <p class="font-mono text-[10px] uppercase tracking-widest text-accent">
              Resultados de enfoque
            </p>
            <div class="mt-6 space-y-6">
              <div class="border-l-2 border-primary-vibrant pl-4">
                <p class="text-3xl font-black text-white">4</p>
                <p class="text-xs uppercase tracking-wider text-slate-300 mt-1">
                  Líneas de servicio
                </p>
              </div>
              <div class="border-l-2 border-accent pl-4">
                <p class="text-3xl font-black text-white">5</p>
                <p class="text-xs uppercase tracking-wider text-slate-300 mt-1">
                  Casos reales activos
                </p>
              </div>
              <div class="border-l-2 border-success pl-4">
                <p class="text-3xl font-black text-white">100%</p>
                <p class="text-xs uppercase tracking-wider text-slate-300 mt-1">
                  Optimización móvil
                </p>
              </div>
            </div>
          </article>
        </div>
      )
    }
  </div>
</section>
