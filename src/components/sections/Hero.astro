---
import Button from '../ui/Button.astro';
import { BRAND_CTA } from '../../lib/constants';

interface Props {
  title?: string;
  subtitle?: string;
  badge?: string;
  primaryCTA?: { label: string; href: string };
  secondaryCTA?: { label: string; href: string };
}

const {
  title = 'Construimos productos digitales <span class="gradient-text">modernos y rentables</span>',
  subtitle = 'Ingeniería de software de alto rendimiento para marcas que buscan dominar su mercado digital mediante experiencias web escalables.',
  badge = 'System Status: Optimal Performance',
  primaryCTA = { label: BRAND_CTA.primary, href: '/contacto' },
  secondaryCTA = { label: BRAND_CTA.secondary, href: '/portafolio' },
} = Astro.props;
---

<section id="hero" class="relative pt-32 pb-20 md:pt-48 md:pb-32 overflow-hidden">
  <div class="container mx-auto px-6 relative z-10">
    <div class="grid lg:grid-cols-12 gap-12 items-center">
      
      {/* Columna Izquierda: Mensaje */}
      <div class="lg:col-span-6 max-w-2xl">
        <div class="inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-4 py-1.5 text-[11px] font-bold uppercase tracking-widest text-primary mb-8 animate-fade-in-up">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
          </span>
          {badge}
        </div>

        <h1 class="text-5xl md:text-7xl font-black leading-[0.95] text-text-primary tracking-tight mb-8">
          <Fragment set:html={title} />
        </h1>

        <p class="mt-6 max-w-xl text-lg leading-relaxed text-text-secondary animate-fade-in-up" style="animation-delay: 100ms">
          {subtitle}
        </p>

        <div class="mt-10 flex flex-col sm:flex-row items-center justify-start gap-4 animate-fade-in-up" style="animation-delay: 200ms">
          <Button href={primaryCTA.href} variant="primary" size="lg" className="w-full sm:w-auto font-black shadow-xl shadow-primary/30">
            {primaryCTA.label}
          </Button>
          <Button href={secondaryCTA.href} variant="secondary" size="lg" className="w-full sm:w-auto font-bold border-border-subtle">
            {secondaryCTA.label}
          </Button>
        </div>
      </div>

      {/* Columna Derecha: Icono Lottie (Más grande) */}
      <div class="lg:col-span-6 relative flex justify-center items-center animate-fade-in-up" style="animation-delay: 300ms">
        {/* Efecto de resplandor técnico de fondo expandido */}
        <div class="absolute w-[90%] h-[90%] bg-primary/20 blur-[120px] rounded-full opacity-30 animate-pulse"></div>
        
        <div class="relative w-full max-w-[650px] aspect-square rounded-[40px] border border-border-subtle bg-bg-card/30 backdrop-blur-3xl shadow-2xl flex items-center justify-center p-4 group overflow-hidden">
          {/* Aquí cargará el icono Lottie */}
          <div id="lottie-container" class="w-full h-full transition-transform duration-700 group-hover:scale-105"></div>
          
          {/* Overlay de ruido digital sutil */}
          <div class="absolute inset-0 opacity-[0.03] pointer-events-none bg-[url('https://grainy-gradients.vercel.app/noise.svg')]"></div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  // Carga dinámica del reproductor de Lottie
  import lottie from 'lottie-web';

  const initLottie = () => {
    const container = document.getElementById('lottie-container');
    if (!container) return;

    lottie.loadAnimation({
      container: container,
      renderer: 'svg',
      loop: true,
      autoplay: true,
      // INSTRUCCIÓN: Reemplaza la URL de abajo por el path de tu archivo JSON descargado
      path: '/public/hero-icon.json',
      //path: 'https://assets9.lottiefiles.com/packages/lf20_m6cuL6.json', 
    });
  };

  document.addEventListener('astro:page-load', initLottie);
  initLottie();
</script>
