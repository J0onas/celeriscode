---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost' | 'success';
  size?: 'sm' | 'md' | 'lg';
  className?: string;
  [key: string]: unknown;
  }

  const {
  href,
  variant = 'primary',
  size = 'md',
  className = '',
  ...rest
  } = Astro.props as Props;

const variants = {
  primary:
    'bg-gradient-to-r from-primary-vibrant to-accent text-white shadow-lg shadow-sky-600/20 hover:scale-[1.02] hover:opacity-95',
  secondary:
    'bg-white/10 text-white border border-white/15 hover:border-primary-vibrant/50 hover:text-primary-vibrant',
  outline:
    'border border-white/20 text-slate-200 hover:border-primary-vibrant/50 hover:text-primary-vibrant',
  ghost: 'text-slate-300 hover:text-white hover:bg-white/5',
  success: 'bg-success text-white shadow-lg shadow-teal-600/20 hover:scale-[1.02] hover:opacity-95',
};

const sizes = {
  sm: 'px-4 py-2 text-xs font-semibold',
  md: 'px-6 py-2.5 text-sm font-bold',
  lg: 'px-8 py-4 text-base font-bold',
};

const Element = href ? 'a' : 'button';
const baseStyles =
  'inline-flex items-center justify-center rounded-xl transition-all duration-220 disabled:opacity-50 disabled:pointer-events-none';
---

<Element href={href} class:list={[baseStyles, variants[variant], sizes[size], className]} {...rest}>
  <slot />
</Element>
