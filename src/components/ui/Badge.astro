---
interface Props {
  className?: string;
  variant?: 'default' | 'accent' | 'success' | 'outline';
}

const { className = '', variant = 'default' } = Astro.props;

const variants = {
  default: 'border-white/12 bg-white/5 text-slate-300',
  accent: 'border-accent/30 bg-accent/10 text-accent',
  success: 'border-success/30 bg-success/10 text-success',
  outline: 'border-white/20 bg-transparent text-slate-300',
};
---

<span
  class:list={[
    'inline-flex items-center rounded-full px-3 py-1 text-[11px] font-bold uppercase tracking-wider border transition-colors',
    variants[variant],
    className,
  ]}
>
  <slot />
</span>
