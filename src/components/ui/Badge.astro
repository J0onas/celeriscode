---
interface Props {
 className?: string;
 variant?: 'default' | 'primary' | 'accent' | 'success' | 'outline' | 'primary-vibrant' | 'accent-vibrant' | 'success-vibrant';
}

const { className = '', variant = 'primary' } = Astro.props;

const variants = {
 default: 'border-border-subtle bg-bg-card text-text-secondary',
 primary: 'border-primary-vibrant/30 bg-primary-vibrant/10 text-primary-vibrant',
 'primary-vibrant': 'border-primary-vibrant/40 bg-primary-vibrant/20 text-primary-vibrant shadow-sm shadow-primary-vibrant/20',
 accent: 'border-accent/30 bg-accent/10 text-accent',
 'accent-vibrant': 'border-accent/40 bg-accent/20 text-accent shadow-sm shadow-accent/20',
 success: 'border-success/30 bg-success/10 text-success',
 'success-vibrant': 'border-success/40 bg-success/20 text-success shadow-sm shadow-success/20',
 outline: 'border-border-subtle bg-transparent text-text-secondary',
};
---

<span
 class:list={[
 'inline-flex items-center rounded-full px-3 py-1 text-[11px] font-bold uppercase tracking-wider border transition-all duration-300',
 variants[variant as keyof typeof variants] || variants.primary,
 className,
 ]}
>
 <slot />
</span>
