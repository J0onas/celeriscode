---
import Badge from './Badge.astro';

interface Props {
 title: string;
 subtitle?: string;
 badge?: string;
 align?: 'left' | 'center';
 className?: string;
 titleClassName?: string;
}

const {
 title,
 subtitle,
 badge,
 align = 'center',
 className = '',
 titleClassName = '',
} = Astro.props;

const alignment = {
 left: 'text-left',
 center: 'text-center mx-auto',
};
---

<div class:list={['max-w-4xl', alignment[align], className]}>
 {
 badge && (
 <div class="mb-6">
 <Badge variant="primary-vibrant">{badge}</Badge>
 </div>
 )
 }

 <h2
 class:list={['text-3xl md:text-5xl font-extrabold tracking-tight text-text-primary', titleClassName]}
 >
 {title.includes('<span') ? <Fragment set:html={title} /> : title}
 </h2>

 {
 subtitle && (
 <p class="mt-5 text-base md:text-lg leading-relaxed text-text-secondary max-w-3xl mx-auto">
 {subtitle}
 </p>
 )
 }
</div>
