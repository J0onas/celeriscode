---
interface Props {
 className?: string;
 isPremium?: boolean;
 padding?: 'none' | 'sm' | 'md' | 'lg';
 hover?: boolean;
 [key: string]: unknown;
}

const {
 className = '',
 isPremium = false,
 padding = 'md',
 hover = true,
 ...rest
} = Astro.props;

const paddings = {
 none: 'p-0',
 sm: 'p-4',
 md: 'p-6',
 lg: 'p-8 lg:p-10',
};

const baseStyles =
  'spotlight-card relative overflow-hidden rounded-3xl transition-all duration-300 bg-bg-card border border-border-subtle shadow-elegant';
const premiumStyles = 'ring-1 ring-primary/20 dark:ring-white/10';
const hoverStyles = 'hover-lift hover:border-primary/40 dark:hover:border-primary/30';
---

<div
 class:list={[
 baseStyles,
 isPremium && premiumStyles,
 hover && hoverStyles,
 paddings[padding],
 className,
 ]}
 {...rest}
>
 {isPremium && (
 <div class="absolute inset-0 pointer-events-none bg-gradient-to-br from-primary/5 via-transparent to-accent/5 opacity-50"></div>
 )}
 <div class="relative z-10">
 <slot />
 </div>
</div>
