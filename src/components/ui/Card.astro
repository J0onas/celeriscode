---
interface Props {
  className?: string;
  isPremium?: boolean;
  padding?: 'none' | 'sm' | 'md' | 'lg';
  hover?: boolean;
  [key: string]: unknown;
  }

  const {
  className = '',
  isPremium = false,
  padding = 'md',
  hover = true,
  ...rest
  } = Astro.props as Props;

const paddings = {
  none: 'p-0',
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8 lg:p-10',
};

const baseStyles =
  'relative overflow-hidden rounded-3xl backdrop-blur-xl border border-white/12 bg-white/5 transition-all duration-300';
const premiumStyles = 'bg-white/8 shadow-inner-white';
const hoverStyles = 'hover:border-white/24 hover:bg-white/10 hover:-translate-y-1';
---

<div
  class:list={[
    baseStyles,
    isPremium && premiumStyles,
    hover && hoverStyles,
    paddings[padding],
    className,
  ]}
  {...rest}
>
  <slot />
</div>

<style>
  .shadow-inner-white {
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.06);
  }
</style>
