---
import { getCollection, render } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import SectionTitle from '../../components/ui/SectionTitle.astro';
import Button from '../../components/ui/Button.astro';
import Card from '../../components/ui/Card.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';

import { PROJECT_TYPE_LABEL } from '../../lib/site-config';
import { getRelatedCasesForService, getServiceTypeForSlug } from '../../lib/content-helpers';
import { SERVICE_DETAIL_VISUALS } from '../../lib/service-assets';

export async function getStaticPaths() {
  const services = await getCollection('services');
  const cases = await getCollection('cases');

  return services.map((entry) => ({
    params: { slug: entry.id },
    props: {
      entry,
      relatedCases: getRelatedCasesForService(cases, entry.id),
    },
  }));
}

const { entry, relatedCases = [] } = Astro.props;
const { Content } = await render(entry);

const visual = SERVICE_DETAIL_VISUALS[entry.id as keyof typeof SERVICE_DETAIL_VISUALS] ?? SERVICE_DETAIL_VISUALS['landing-page'];
const serviceType = getServiceTypeForSlug(entry.id);

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: entry.data.title,
  description: entry.data.description,
  serviceType: PROJECT_TYPE_LABEL[serviceType],
  provider: {
    '@type': 'Organization',
    name: 'Celeris Code',
  },
};
---

<MainLayout
  title={`${entry.data.title} | Celeris Code`}
  description={entry.data.description}
  image={visual.hero}
  schema={serviceSchema}
>
  <!-- Hero -->
  <section class="relative overflow-hidden pt-24 pb-12">
    <div class="pointer-events-none absolute inset-0 -z-20">
      <div class="aurora-blue absolute -left-[10%] top-[-10%] h-96 w-96 opacity-40"></div>
      <div class="aurora-purple absolute right-[-10%] top-[10%] h-80 w-80 opacity-30"></div>
    </div>

    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-7">
          <SectionTitle
            align="left"
            badge="Servicio Especializado"
            title={entry.data.title}
            subtitle={entry.data.description}
            className="mb-8"
          />

          <div class="flex flex-wrap gap-3 mb-10">
            <Button href="/contacto" variant="primary" size="lg">Impulsa tu Proyecto</Button>
            <Button href="/portafolio" variant="secondary" size="lg">Ver portafolio</Button>
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <Card
              padding="sm"
              hover={false}
              className="flex items-center gap-4 bg-white/3 border-white/5"
            >
              <div
                class="w-10 h-10 rounded-xl bg-primary-vibrant/10 flex items-center justify-center text-primary-vibrant"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg
                >
              </div>
              <div>
                <p class="text-[10px] uppercase font-bold text-slate-300">Duración</p>
                <p class="text-sm font-bold text-white">{entry.data.duration ?? 'Iterativo'}</p>
              </div>
            </Card>
            <Card
              padding="sm"
              hover={false}
              className="flex items-center gap-4 bg-white/3 border-white/5"
            >
              <div
                class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center text-accent"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg
                >
              </div>
              <div>
                <p class="text-[10px] uppercase font-bold text-slate-300">Enfoque</p>
                <p class="text-sm font-bold text-white">{visual.badge}</p>
              </div>
            </Card>
          </div>
        </div>

        <div class="lg:col-span-5 relative">
          <Card padding="none" isPremium className="overflow-hidden group">
            <img
              src={visual.hero}
              alt={entry.data.title}
              class="w-full h-auto grayscale-[0.2] group-hover:grayscale-0 transition-all duration-700"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-950/40 to-transparent"></div>
          </Card>
        </div>
      </div>
    </div>
  </section>

  <!-- Details Grid -->
  <section class="py-20 bg-slate-900/20">
    <div class="container mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-8 max-w-6xl mx-auto">
        <Card isPremium padding="lg">
          <h2 class="text-2xl font-bold text-white mb-8 border-l-4 border-primary-vibrant pl-4">
            Qué incluye
          </h2>
          <ul class="space-y-4">
            {
              entry.data.deliverables.map((item: string) => (
                <li class="flex items-start gap-3 text-slate-300">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-5 w-5 text-primary-vibrant shrink-0 mt-0.5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M5 13l4 4L19 7"
                    />
                  </svg>
                  <span class="text-sm leading-relaxed">{item}</span>
                </li>
              ))
            }
          </ul>
        </Card>

        <Card isPremium padding="lg">
          <h2 class="text-2xl font-bold text-white mb-8 border-l-4 border-accent pl-4">
            Escenarios ideales
          </h2>
          <ul class="space-y-4">
            {
              entry.data.idealFor.map((item: string) => (
                <li class="flex items-start gap-3 text-slate-300">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-5 w-5 text-accent shrink-0 mt-0.5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M13 10V3L4 14h7v7l9-11h-7z"
                    />
                  </svg>
                  <span class="text-sm leading-relaxed">{item}</span>
                </li>
              ))
            }
          </ul>
        </Card>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-20">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        <Card padding="lg" isPremium className="content-rich">
          <Content />
        </Card>
      </div>
    </div>
  </section>

  <!-- Related Cases -->
  {
    relatedCases.length > 0 && (
      <section class="py-24 bg-slate-900/30">
        <div class="container mx-auto px-6">
          <SectionTitle
            badge="Portafolio Relacionado"
            title="Cómo aplicamos este <span class='gradient-text'>enfoque</span>"
            className="mb-16"
          />

          <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
            {relatedCases.map((item) => (
              <Card padding="none" className="group">
                <div class="aspect-video overflow-hidden border-b border-white/10 relative">
                  <img
                    src={item.data.image}
                    alt={item.data.title}
                    class="w-full h-full object-cover transition-transform group-hover:scale-105 duration-500"
                  />
                </div>
                <div class="p-6">
                  <p class="text-[10px] font-mono uppercase tracking-widest text-slate-300 mb-2">
                    {item.data.client}
                  </p>
                  <h3 class="text-lg font-bold text-white mb-4 group-hover:text-primary-vibrant transition-colors">
                    {item.data.title}
                  </h3>
                  <Button
                    href={item.data.url}
                    target="_blank"
                    variant="ghost"
                    size="sm"
                    className="p-0 hover:bg-transparent"
                  >
                    Visitar sitio &rarr;
                  </Button>
                </div>
              </Card>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <FinalCTA
    title={`Inicia tu proyecto de <span class="gradient-text">${entry.data.title}</span> ahora`}
    subtitle={entry.data.ctaOffer ||
      'Te contactaremos para definir el alcance, tiempos y presupuesto de tu solución.'}
  />
</MainLayout>
