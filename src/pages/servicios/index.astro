---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import SectionTitle from '../../components/ui/SectionTitle.astro';
import Button from '../../components/ui/Button.astro';
import Card from '../../components/ui/Card.astro';
import Badge from '../../components/ui/Badge.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';

import { SERVICE_LIST_MEDIA, getServiceIcon } from '../../lib/service-assets';
import { PROCESS_STEPS } from '../../lib/constants';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);

const trustMetrics = [
  {
    label: 'Líneas de servicio',
    value: String(services.length),
    description: 'Rutas especializadas para distintas etapas de negocio.',
    icon: 'rocket',
  },
  {
    label: 'Enfoque',
    value: 'UI/UX + CRO',
    description: 'Diseño orientado a decisión y conversión.',
    icon: 'spark',
  },
  {
    label: 'Implementación',
    value: 'Modular',
    description: 'Crecimiento por fases sin rehacer desde cero.',
    icon: 'layers',
  },
];

const servicesSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: services.map((service, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    item: {
      '@type': 'Service',
      name: service.data.title,
      description: service.data.description,
      url: `/servicios/${service.id}`,
    },
  })),
};
---

<MainLayout
  title="Servicios | Celeris Code"
  description="Soluciones de software de alto rendimiento para marcas que buscan dominar su mercado digital."
  schema={servicesSchema}
>
  <!-- Hero / Introduction -->
  <section class="relative overflow-hidden pt-24 pb-12">
    <div class="pointer-events-none absolute inset-0 -z-20">
      <div class="aurora-blue absolute -left-[10%] top-[-10%] h-80 w-80 opacity-55"></div>
      <div class="aurora-purple absolute right-[-10%] top-[6%] h-80 w-80 opacity-50"></div>
    </div>

    <div class="container mx-auto px-6">
      <SectionTitle
        badge="Servicios Estratégicos"
        title="Construimos el <span class='gradient-text'>activo digital</span> que tu negocio necesita"
        subtitle="Desde landing pages de alta conversión hasta plataformas SaaS escalables. Elige la ruta que mejor encaje con tu etapa actual."
        className="mb-12"
      />

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          trustMetrics.map((item) => (
            <Card className="text-center" hover={false}>
              <div class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-primary-vibrant/35 bg-primary-vibrant/10 text-primary-vibrant mb-4">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.7"
                    d={getServiceIcon(item.icon)}
                  />
                </svg>
              </div>
              <p class="text-2xl font-black text-text-primary">{item.value}</p>
              <p class="text-sm text-text-secondary mt-1">{item.description}</p>
            </Card>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Service Grid -->
  <section id="rutas-servicio" class="py-20 relative">
    <div class="container mx-auto px-6">
      <div class="grid gap-8 lg:grid-cols-2">
        {
          services.map((service, index) => {
            const media = SERVICE_LIST_MEDIA[service.id as keyof typeof SERVICE_LIST_MEDIA];
            return (
              <Card padding="none" isPremium data-reveal style={`--reveal-delay: ${index * 100}ms`}>
                <div class="flex flex-col lg:flex-row h-full">
                  <div class="lg:w-2/5 shrink-0 overflow-hidden border-b lg:border-b-0 lg:border-r border-border-subtle">
                    <img
                      src={media?.image ?? '/assets/projects/posmart.png'}
                      alt={media?.alt ?? service.data.title}
                      class="h-full w-full object-cover grayscale-[0.3] group-hover:grayscale-0 transition-all duration-500"
                      loading="lazy"
                    />
                  </div>

                  <div class="p-8 flex flex-col justify-between flex-1">
                    <div>
                      <div class="flex flex-wrap gap-2 mb-4">
                        <Badge variant="primary-vibrant">{media?.metric}</Badge>
                        {service.data.duration && (
                          <Badge variant="outline">{service.data.duration}</Badge>
                        )}
                      </div>

                      <h3 class="text-2xl font-bold text-text-primary mb-4">{service.data.title}</h3>
                      <p class="text-sm text-text-secondary leading-relaxed mb-6">
                        {service.data.description}
                      </p>

                      <div class="mb-8">
                        <p class="font-mono text-[10px] uppercase tracking-widest text-text-secondary mb-3">
                          Qué incluye
                        </p>
                        <ul class="space-y-2">
                          {service.data.deliverables.slice(0, 3).map((item: string) => (
                            <li class="flex items-start gap-2 text-xs text-text-secondary">
                              <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-primary-vibrant" />
                              <span>{item}</span>
                            </li>
                          ))}
                        </ul>
                      </div>
                    </div>

                    <div class="flex items-center justify-between gap-4 pt-4 border-t border-border-subtle">
                      {service.data.pricingHint && (
                        <span class="text-xs font-semibold text-text-secondary">
                          {service.data.pricingHint}
                        </span>
                      )}
                      <Button href={`/servicios/${service.id}`} variant="primary" size="sm">
                        {service.data.ctaText}
                      </Button>
                    </div>
                  </div>
                </div>
              </Card>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- How we work -->
  <section class="py-20 md:py-32 overflow-hidden relative">
    <div class="container mx-auto px-6">
      <SectionTitle
        badge="Proceso"
        title="Cómo trabajamos <span class='gradient-text'>tu proyecto</span>"
        subtitle="Un marco de trabajo ágil y transparente diseñado para maximizar el retorno de tu inversión."
        className="mb-24"
      />

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4 relative">
        {/* Connection line for desktop */}
        <div class="hidden lg:block absolute top-1/2 left-0 w-full h-px bg-gradient-to-r from-transparent via-border-subtle to-transparent -translate-y-12 z-0"></div>

        {
          PROCESS_STEPS.map((step, index) => (
            <Card 
              padding="lg"
              className="relative z-10 group flex flex-col items-center text-center h-full" 
              data-reveal 
              style={`--reveal-delay: ${index * 150}ms`}
            >
              {/* Step number background bubble */}
              <div class="absolute -top-3 -right-3 w-12 h-12 rounded-full bg-bg-card border border-primary-vibrant/20 shadow-md flex items-center justify-center text-lg font-black text-primary-vibrant/80 group-hover:scale-110 transition-all duration-500 select-none">
                {step.id}
              </div>

              {/* Icon Container with Glass Effect */}
              <div class="mb-6 inline-flex h-14 w-14 items-center justify-center rounded-2xl backdrop-blur-md bg-primary-vibrant/10 text-primary-vibrant border border-primary-vibrant/20 shadow-inner group-hover:bg-primary-vibrant group-hover:text-white group-hover:rotate-6 group-hover:shadow-lg group-hover:shadow-primary-vibrant/30 transition-all duration-500">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-7 w-7"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d={getServiceIcon(step.icon)}
                  />
                </svg>
              </div>

              <h3 class="text-xl font-bold text-text-primary mb-3">{step.title}</h3>
              <p class="text-sm text-text-secondary leading-relaxed">{step.description}</p>
            </Card>
          ))
        }
      </div>
    </div>
  </section>

  <FinalCTA />
</MainLayout>
