---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const services = (await getCollection('services'))
  .sort((a, b) => a.data.order - b.data.order);

const iconByService: Record<string, string> = {
  rocket: 'M5 12l5.5 5.5M4 20l5-1 9-9a4 4 0 10-5.66-5.66l-9 9-1 5z',
  layers: 'M12 3l9 4.5-9 4.5-9-4.5L12 3zm-9 9l9 4.5 9-4.5M3 16.5l9 4.5 9-4.5',
  cart: 'M3 4h2l1 10h11l2-7H6M9 20a1 1 0 100-2 1 1 0 000 2zm8 0a1 1 0 100-2 1 1 0 000 2z',
  spark: 'M12 3l2.5 5.5L20 11l-5.5 2.5L12 19l-2.5-5.5L4 11l5.5-2.5L12 3z',
};
---

<MainLayout
  title="Servicios | Celeris Code"
  description="Servicios de Celeris Code: landing page, multipage, ecommerce y SaaS con enfoque en UI/UX, rendimiento y conversión."
>
  <section class="container mx-auto px-6 py-20">
    <div class="max-w-3xl">
      <span class="pill">Servicios</span>
      <h1 class="section-title mt-6">Soluciones diseñadas para crecer tu negocio</h1>
      <p class="section-subtitle mt-5">
        Trabajamos con una metodología orientada a resultados: claridad estratégica,
        diseño de experiencia y ejecución técnica enfocada en rendimiento.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      {services.map((service) => (
        <article class="bento-card">
          <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-xl border border-primary-vibrant/35 bg-primary-vibrant/10 text-primary-vibrant">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={iconByService[service.data.icon ?? 'spark'] ?? iconByService.spark} />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-white">{service.data.title}</h2>
          <p class="mt-3 text-slate-300">{service.data.description}</p>
          {service.data.highlight && <p class="mt-4 text-sm font-semibold text-primary-vibrant">{service.data.highlight}</p>}

          {service.data.deliverables.length > 0 && (
            <ul class="mt-5 space-y-2 text-sm text-slate-300">
              {service.data.deliverables.slice(0, 3).map((item) => (
                <li class="flex items-start gap-2">
                  <span class="mt-1 h-2 w-2 rounded-full bg-primary-vibrant"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          )}

          <div class="mt-6 flex flex-wrap gap-2 text-xs">
            {service.data.duration && <span class="pill">{service.data.duration}</span>}
            {service.data.pricingHint && <span class="pill">{service.data.pricingHint}</span>}
          </div>

          <a href={`/servicios/${service.id}`} class="mt-6 inline-flex text-sm font-semibold text-primary-vibrant hover:text-sky-300">
            {service.data.ctaText} &rarr;
          </a>
        </article>
      ))}
    </div>
  </section>

  <section class="pb-10">
    <div class="container mx-auto px-6">
      <div class="bento-card-premium mx-auto max-w-4xl p-8 text-center">
        <h2 class="text-3xl font-extrabold text-white md:text-4xl">¿No tienes claro qué servicio necesitas?</h2>
        <p class="mx-auto mt-4 max-w-2xl text-slate-300">
          Te ayudamos a definir la mejor ruta según etapa de negocio, canales de venta y objetivos comerciales.
        </p>
        <a href="/contacto" class="mt-7 inline-flex rounded-xl bg-gradient-to-r from-primary-vibrant to-accent px-8 py-4 font-bold text-white">
          Agenda una conversación
        </a>
      </div>
    </div>
  </section>
</MainLayout>
