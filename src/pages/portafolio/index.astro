---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const cases = await getCollection('cases');

const portfolioOrder = [
  'posmart-saas',
  'inperu-landing',
  'turquesa-travel-multipage',
  'el-bambino-menu-digital',
  'zoi-beauty-ecommerce',
];

const portfolioCases = portfolioOrder
  .map((slug) => cases.find((item) => item.id === slug))
  .filter((item): item is (typeof cases)[number] => Boolean(item));

const projectTypeLabel: Record<string, string> = {
  'saas': 'SaaS',
  'landing-page': 'Landing Page',
  'multipage': 'Multipage',
  'ecommerce': 'Ecommerce',
};

const projectTypeCount = portfolioCases.reduce((acc, item) => {
  acc[item.data.projectType] = (acc[item.data.projectType] ?? 0) + 1;
  return acc;
}, {} as Record<string, number>);
---

<MainLayout title="Portafolio | Celeris Code" description="Portafolio real de Celeris Code con proyectos publicados en SaaS, landing page, multipage y ecommerce.">
  <section class="container mx-auto px-6 py-20">
    <div class="max-w-4xl">
      <span class="pill">Portafolio real</span>
      <h1 class="section-title mt-6">Proyectos reales desarrollados por Celeris Code</h1>
      <p class="section-subtitle mt-5">
        Basado en tu línea de servicios y casos publicados: POSmart, InPerú, Turquesa Travel,
        El Bambino y ZoiBeauty.
      </p>
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-4">
      <article class="bento-card">
        <p class="text-technical">CASOS PUBLICADOS</p>
        <p class="mt-2 text-3xl font-black text-white">{portfolioCases.length}</p>
        <p class="mt-1 text-sm text-slate-300">Sitios y productos con link activo.</p>
      </article>
      <article class="bento-card">
        <p class="text-technical">LANDING PAGE</p>
        <p class="mt-2 text-3xl font-black text-white">{projectTypeCount['landing-page'] ?? 0}</p>
        <p class="mt-1 text-sm text-slate-300">Institucional y menú digital.</p>
      </article>
      <article class="bento-card">
        <p class="text-technical">MULTIPAGE</p>
        <p class="mt-2 text-3xl font-black text-white">{projectTypeCount['multipage'] ?? 0}</p>
        <p class="mt-1 text-sm text-slate-300">Arquitectura de contenido por secciones.</p>
      </article>
      <article class="bento-card">
        <p class="text-technical">SAAS + ECOMMERCE</p>
        <p class="mt-2 text-3xl font-black text-white">{(projectTypeCount['saas'] ?? 0) + (projectTypeCount['ecommerce'] ?? 0)}</p>
        <p class="mt-1 text-sm text-slate-300">Producto digital y venta online.</p>
      </article>
    </div>

    <div class="mt-8 bento-card">
      <p class="text-technical mb-4">Navegación rápida</p>
      <div class="flex flex-wrap gap-2">
        {portfolioCases.map((item, index) => (
          <a href={item.data.url} target="_blank" rel="noopener noreferrer" class="pill hover:text-primary-vibrant">
            {index + 1}. {item.data.client}
          </a>
        ))}
      </div>
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-2">
      {portfolioCases.map((item, index) => (
        <article class="bento-card overflow-hidden">
          <img src={item.data.image} alt={`Portada ${item.data.title}`} class="aspect-video w-full rounded-2xl border border-white/10 object-cover" loading="lazy" />

          <div class="mt-5 flex flex-wrap gap-2">
            <span class="pill">Proyecto #{index + 1}</span>
            <span class="pill">{projectTypeLabel[item.data.projectType] ?? item.data.projectType}</span>
            <span class="pill">{item.data.industry}</span>
          </div>

          <h2 class="mt-4 text-2xl font-bold text-white">{item.data.title}</h2>
          <p class="mt-2 text-sm leading-relaxed text-slate-300">{item.data.summary}</p>

          <div class="mt-5 grid gap-4 sm:grid-cols-2">
            <div>
              <p class="text-technical">Resultados clave</p>
              <ul class="mt-2 space-y-2 text-sm text-slate-300">
                {item.data.results.slice(0, 3).map((result) => (
                  <li class="flex items-start gap-2">
                    <span class="mt-1 h-2 w-2 rounded-full bg-primary-vibrant"></span>
                    <span>{result}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div>
              <p class="text-technical">Stack / enfoque</p>
              <div class="mt-2 flex flex-wrap gap-2">
                {item.data.stack.map((tech) => (
                  <span class="pill">{tech}</span>
                ))}
              </div>
            </div>
          </div>

          <div class="mt-6 flex flex-wrap items-center gap-3">
            <a href={item.data.url} target="_blank" rel="noopener noreferrer" class="rounded-lg bg-gradient-to-r from-primary-vibrant to-accent px-5 py-2.5 text-sm font-bold text-white">
              Ver sitio en vivo
            </a>
            <span class="text-xs text-slate-400">{item.data.client}</span>
          </div>
        </article>
      ))}
    </div>
  </section>
</MainLayout>
