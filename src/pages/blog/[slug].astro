---
import { getCollection, render } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import Button from '../../components/ui/Button.astro';
import Card from '../../components/ui/Card.astro';
import Badge from '../../components/ui/Badge.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, allPosts: posts },
  }));
}

const { entry, allPosts } = Astro.props;
const { Content, headings } = await render(entry);

const relatedPosts = allPosts
  .filter((p) => p.id !== entry.id && p.data.tags.some((t) => entry.data.tags.includes(t)))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('es-ES', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);

const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: entry.data.title,
  description: entry.data.description ?? entry.data.excerpt,
  image: entry.data.cover,
  datePublished: entry.data.date.toISOString(),
  author: {
    '@type': 'Person',
    name: entry.data.author.name,
    jobTitle: entry.data.author.role,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `/blog/${entry.id}`,
  },
};

const currentUrl = Astro.url.href;
const shareText = encodeURIComponent(`He leído "${entry.data.title}" en Celeris Code. ¡Altamente recomendado!`);
---

<MainLayout
  title={`${entry.data.title} | Blog Celeris Code`}
  description={entry.data.description ?? entry.data.excerpt}
  image={entry.data.cover}
  schema={blogPostingSchema}
  article={true}
>
  <!-- Reading Progress Bar -->
  <div id="progress-container" class="fixed top-0 left-0 w-full h-1 z-[100] bg-transparent">
    <div id="progress-bar" class="h-full bg-primary-vibrant w-0 transition-all duration-150"></div>
  </div>

  <!-- Article Header -->
  <section class="relative overflow-hidden pt-24 pb-12">
    <div class="pointer-events-none absolute inset-0 -z-20">
      <div class="aurora-blue absolute -left-[10%] top-[-10%] h-96 w-96 opacity-30"></div>
      <div class="aurora-purple absolute right-[-10%] top-[10%] h-80 w-80 opacity-20"></div>
    </div>

    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        <nav
          class="flex items-center gap-2 text-[10px] font-mono uppercase tracking-widest text-text-secondary mb-8"
          aria-label="Breadcrumb"
        >
          <a href="/blog" class="hover:text-primary-vibrant transition-colors">Blog</a>
          <span class="w-1 h-1 rounded-full bg-slate-700"></span>
          <span class="text-text-secondary">Artículo</span>
        </nav>

        <div class="flex flex-wrap gap-2 mb-6">
          {entry.data.tags.map((tag: string) => <Badge variant="primary-vibrant">{tag}</Badge>)}
        </div>

        <h1 class="text-4xl md:text-6xl font-black text-text-primary leading-[1.1] tracking-tight mb-8">
          {entry.data.title}
        </h1>

        <div class="flex items-center gap-6 text-sm text-text-secondary border-y border-border-subtle py-6">
          <div class="flex items-center gap-3">
            {entry.data.author.avatar ? (
              <img src={entry.data.author.avatar} alt={entry.data.author.name} class="w-10 h-10 rounded-full border border-border-subtle" />
            ) : (
              <div class="w-10 h-10 rounded-full bg-gradient-to-tr from-primary-vibrant to-accent flex items-center justify-center text-xs font-bold text-text-primary">
                {entry.data.author.name.charAt(0)}
              </div>
            )}
            <div class="flex flex-col">
              <span class="font-bold text-text-primary leading-none mb-1">{entry.data.author.name}</span>
              <span class="text-[10px] uppercase tracking-wider">{entry.data.author.role}</span>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            <span>{formatDate(entry.data.date)}</span>
          </div>
          <Badge variant="outline">{entry.data.readingTime}</Badge>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content Area -->
  <section class="pb-24">
    <div class="container mx-auto px-6 max-w-6xl">
      <div class="grid lg:grid-cols-12 gap-12">
        <!-- Content Column -->
        <div class="lg:col-span-8">
          <!-- Featured Image -->
          <Card padding="none" isPremium className="overflow-hidden shadow-2xl mb-12">
            <img
              src={entry.data.cover}
              alt={entry.data.title}
              class="w-full aspect-video object-cover"
              loading="eager"
            />
          </Card>

          <!-- The Article -->
          <Card padding="lg" isPremium className="content-rich shadow-xl border-border-subtle">
            <Content />
          </Card>

          <!-- Tags & Back -->
          <div class="mt-16 pt-12 border-t border-border-subtle flex flex-col sm:flex-row items-center justify-between gap-8">
            <div class="flex flex-wrap gap-2">
              {entry.data.tags.map((tag: string) => <Badge variant="outline">{tag}</Badge>)}
            </div>
            <Button href="/blog" variant="ghost" className="group">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
              </svg>
              Volver al Blog
            </Button>
          </div>

          <!-- Author Box -->
          <div class="mt-16 p-8 rounded-2xl bg-bg-card border border-border-subtle flex flex-col md:flex-row gap-8 items-center md:items-start text-center md:text-left">
            <div class="shrink-0">
              {entry.data.author.avatar ? (
                <img src={entry.data.author.avatar} alt={entry.data.author.name} class="w-24 h-24 rounded-2xl border border-border-subtle" />
              ) : (
                <div class="w-24 h-24 rounded-2xl bg-gradient-to-tr from-primary-vibrant to-accent flex items-center justify-center text-2xl font-bold text-text-primary">
                  {entry.data.author.name.charAt(0)}
                </div>
              )}
            </div>
            <div class="flex-1">
              <h3 class="text-xl font-bold text-text-primary mb-2">{entry.data.author.name}</h3>
              <p class="text-primary-vibrant font-mono text-xs uppercase tracking-widest mb-4">{entry.data.author.role}</p>
              <p class="text-text-secondary leading-relaxed mb-6">
                {entry.data.author.bio || 'Expertos en ingeniería de activos digitales de alto rendimiento.'}
              </p>
              <div class="flex items-center justify-center md:justify-start gap-4">
                {entry.data.author.twitter && (
                  <a href={entry.data.author.twitter} class="text-text-secondary hover:text-primary-vibrant transition-colors">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
                  </a>
                )}
                {entry.data.author.linkedin && (
                  <a href={entry.data.author.linkedin} class="text-text-secondary hover:text-primary-vibrant transition-colors">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.761 0 5-2.239 5-5v-14c0-2.761-2.239-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"></path></svg>
                  </a>
                )}
              </div>
            </div>
          </div>
        </div>

        <!-- Sidebar Column -->
        <aside class="lg:col-span-4 space-y-8">
          <!-- Table of Contents -->
          {headings.length > 0 && (
            <div class="sticky top-32 p-8 rounded-2xl bg-bg-card border border-border-subtle">
              <h4 class="text-xs font-mono uppercase tracking-widest text-text-primary mb-6 flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-primary-vibrant"></span>
                Contenido
              </h4>
              <nav class="space-y-4 max-h-[50vh] overflow-y-auto pr-2 scrollbar-thin">
                {headings.filter(h => h.depth <= 3).map((heading) => (
                  <a
                    href={`#${heading.slug}`}
                    class={`block text-sm transition-all hover:text-primary-vibrant ${
                      heading.depth === 3 ? 'pl-4 text-text-secondary' : 'font-bold text-text-primary'
                    }`}
                  >
                    {heading.text}
                  </a>
                ))}
              </nav>

              <div class="mt-8 pt-8 border-t border-border-subtle">
                <h4 class="text-xs font-mono uppercase tracking-widest text-text-primary mb-6">Compartir</h4>
                <div class="flex gap-4">
                  <a
                    href={`https://twitter.com/intent/tweet?text=${shareText}&url=${currentUrl}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-10 h-10 rounded-xl bg-bg-default border border-border-subtle flex items-center justify-center text-text-secondary hover:border-primary-vibrant/50 hover:text-primary-vibrant transition-all"
                    aria-label="Compartir en X (Twitter)"
                  >
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
                  </a>
                  <a
                    href={`https://www.linkedin.com/sharing/share-offsite/?url=${currentUrl}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-10 h-10 rounded-xl bg-bg-default border border-border-subtle flex items-center justify-center text-text-secondary hover:border-primary-vibrant/50 hover:text-primary-vibrant transition-all"
                    aria-label="Compartir en LinkedIn"
                  >
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.761 0 5-2.239 5-5v-14c0-2.761-2.239-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"></path></svg>
                  </a>
                  <a
                    href={`https://wa.me/?text=${shareText}%20${currentUrl}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-10 h-10 rounded-xl bg-bg-default border border-border-subtle flex items-center justify-center text-text-secondary hover:border-primary-vibrant/50 hover:text-primary-vibrant transition-all"
                    aria-label="Compartir en WhatsApp"
                  >
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path></svg>
                  </a>
                  <button
                    id="copy-link"
                    class="w-10 h-10 rounded-xl bg-bg-default border border-border-subtle flex items-center justify-center text-text-secondary hover:border-primary-vibrant/50 hover:text-primary-vibrant transition-all"
                    aria-label="Copiar enlace"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          )}
        </aside>
      </div>
    </div>
  </section>

  <!-- Related -->
  {
    relatedPosts.length > 0 && (
      <section class="py-20 bg-bg-default">
        <div class="container mx-auto px-6 max-w-4xl">
          <div class="flex items-center gap-4 mb-12">
            <div class="h-px flex-1 bg-bg-card" />
            <h2 class="text-xl font-bold text-text-primary uppercase tracking-widest text-center">
              Te puede interesar
            </h2>
            <div class="h-px flex-1 bg-bg-card" />
          </div>

          <div class="grid md:grid-cols-2 gap-8">
            {relatedPosts.map((post) => (
              <a href={`/blog/${post.id}`} class="group">
                <Card
                  padding="none"
                  className="h-full border-border-subtle hover:border-primary-vibrant/30"
                >
                  <div class="aspect-video overflow-hidden">
                    <img
                      src={post.data.cover}
                      alt={post.data.title}
                      class="w-full h-full object-cover transition-transform group-hover:scale-105"
                    />
                  </div>
                  <div class="p-6">
                    <h3 class="text-lg font-bold text-text-primary mb-2 group-hover:text-primary-vibrant transition-colors line-clamp-2">
                      {post.data.title}
                    </h3>
                    <p class="text-xs text-text-secondary">{formatDate(post.data.date)}</p>
                  </div>
                </Card>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <FinalCTA
    title="Aplica estas estrategias en tu <span class='gradient-text'>proyecto</span>"
    subtitle="Te ayudamos a convertir insights estratégicos en resultados de negocio tangibles."
  />
</MainLayout>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    // Reading Progress Bar
    const progressBar = document.getElementById('progress-bar');
    if (progressBar) {
      window.addEventListener('scroll', () => {
        const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
        const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scrolled = (winScroll / height) * 100;
        progressBar.style.width = scrolled + '%';
      });
    }

    // Copy Link
    const copyBtn = document.getElementById('copy-link');
    if (copyBtn) {
      copyBtn.addEventListener('click', () => {
        navigator.clipboard.writeText(window.location.href);
        const originalContent = copyBtn.innerHTML;
        copyBtn.innerHTML = `<svg class="w-4 h-4 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>`;
        setTimeout(() => {
          copyBtn.innerHTML = originalContent;
        }, 2000);
      });
    }

    // TOC Active State
    const observerOptions = {
      root: null,
      rootMargin: '-10% 0px -80% 0px',
      threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const id = entry.target.getAttribute('id');
        const tocLink = document.querySelector(`nav a[href="#${id}"]`);
        
        if (entry.isIntersecting) {
          document.querySelectorAll('nav a').forEach(a => a.classList.remove('text-primary-vibrant', 'font-black'));
          if (tocLink) {
            tocLink.classList.add('text-primary-vibrant', 'font-black');
            tocLink.classList.remove('text-text-secondary');
          }
        }
      });
    }, observerOptions);

    document.querySelectorAll('.content-rich h2, .content-rich h3').forEach((section) => {
      observer.observe(section);
    });
  });
</script>

<style>
  @reference "../../styles/global.css";

  .scrollbar-thin::-webkit-scrollbar {
    width: 2px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    @apply bg-border-subtle rounded-full;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb:hover {
    @apply bg-primary-vibrant/30;
  }
</style>
