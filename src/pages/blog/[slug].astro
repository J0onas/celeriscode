---
import { getCollection, render } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Related posts (same tags, excluding current)
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((p) => p.id !== entry.id && p.data.tags.some((t) => entry.data.tags.includes(t)))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);
---

<MainLayout
  title={`${entry.data.title} | Blog Celeris Code`}
  description={entry.data.description ?? entry.data.excerpt}
  image={entry.data.cover}
>
  <!-- Article Header -->
  <section class="relative overflow-hidden py-20 md:py-28">
    <!-- Background decorations -->
    <div class="absolute left-0 top-0 h-96 w-96 -translate-x-1/2 -translate-y-1/2 rounded-full aurora-blue opacity-30 blur-3xl"></div>
    <div class="absolute right-0 top-40 h-80 w-80 translate-x-1/3 rounded-full aurora-purple opacity-20 blur-3xl"></div>

    <div class="container relative mx-auto px-6">
      <div class="mx-auto max-w-4xl">
        <!-- Breadcrumb -->
        <nav class="mb-8 flex items-center gap-2 text-sm text-slate-400">
          <a href="/blog" class="text-primary-vibrant hover:text-sky-300">
            Blog
          </a>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
          <span class="text-slate-500">Artículo</span>
        </nav>

        <!-- Tags -->
        <div class="mb-6 flex flex-wrap gap-2">
          {entry.data.tags.map((tag: string) => (
            <span class="pill">{tag}</span>
          ))}
        </div>

        <!-- Title -->
        <h1 class="section-title">{entry.data.title}</h1>

        <!-- Excerpt -->
        <p class="mt-6 text-xl leading-relaxed text-slate-300">{entry.data.excerpt}</p>

        <!-- Meta Info -->
        <div class="mt-8 flex flex-wrap items-center gap-6 text-sm text-slate-400">
          <div class="flex items-center gap-2">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-r from-primary-vibrant to-accent font-bold text-white">
              {entry.data.author.charAt(0)}
            </div>
            <span class="font-medium text-slate-300">{entry.data.author}</span>
          </div>
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span>{entry.data.date.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          </div>
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>{entry.data.readingTime} de lectura</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Image -->
  <section class="pb-12">
    <div class="container mx-auto px-6">
      <div class="mx-auto max-w-5xl">
        <div class="relative overflow-hidden rounded-3xl border border-white/10 shadow-2xl">
          <img
            src={entry.data.cover}
            alt={`Portada: ${entry.data.title}`}
            class="aspect-video w-full object-cover"
            loading="eager"
          />
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-primary-deep/40 via-transparent to-transparent"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Article Content -->
  <section class="py-12">
    <div class="container mx-auto px-6">
      <div class="mx-auto max-w-4xl">
        <div class="content-rich bento-card p-8 md:p-12">
          <Content />
        </div>
      </div>
    </div>
  </section>

  <!-- Share & Navigation -->
  <section class="py-12">
    <div class="container mx-auto px-6">
      <div class="mx-auto max-w-4xl">
        <!-- Tags -->
        <div class="mb-8 flex flex-wrap gap-2">
          {entry.data.tags.map((tag: string) => (
            <span class="pill">{tag}</span>
          ))}
        </div>

        <!-- Back to Blog -->
        <a href="/blog" class="group inline-flex items-center gap-3 text-sm font-semibold text-primary-vibrant hover:text-sky-300">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
          Volver al Blog
        </a>
      </div>
    </div>
  </section>

  <!-- Related Articles -->
  {relatedPosts.length > 0 && (
    <section class="py-16">
      <div class="container mx-auto px-6">
        <div class="mx-auto max-w-4xl">
          <div class="mb-8 flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary-vibrant" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
            </svg>
            <h2 class="text-2xl font-bold text-white">Artículos Relacionados</h2>
          </div>

          <div class="grid gap-6 md:grid-cols-2">
            {relatedPosts.map((post) => (
              <article class="group bento-card">
                <div class="relative mb-5 overflow-hidden rounded-xl">
                  <img
                    src={post.data.cover}
                    alt={`Portada: ${post.data.title}`}
                    class="aspect-video w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                  <div class="absolute right-3 top-3">
                    <span class="rounded-lg bg-primary-deep/90 px-2 py-1 text-xs font-semibold text-white backdrop-blur-sm">
                      {post.data.readingTime}
                    </span>
                  </div>
                </div>

                <div class="flex flex-wrap gap-2">
                  {post.data.tags.slice(0, 2).map((tag: string) => (
                    <span class="pill text-xs">{tag}</span>
                  ))}
                </div>

                <h3 class="mt-3 text-lg font-bold text-white group-hover:text-primary-vibrant transition-colors">
                  {post.data.title}
                </h3>

                <p class="mt-2 text-sm text-slate-300">{post.data.excerpt}</p>

                <a href={`/blog/${post.id}`} class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-primary-vibrant transition-all hover:gap-3 hover:text-sky-300">
                  Leer artículo
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- CTA Section -->
  <section class="py-20">
    <div class="container mx-auto px-6">
      <div class="bento-card-premium mx-auto max-w-5xl overflow-hidden p-8 text-center md:p-12">
        <!-- Background decorations -->
        <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full aurora-teal opacity-40 blur-3xl"></div>
        <div class="absolute -bottom-20 -left-20 h-64 w-64 rounded-full aurora-blue opacity-30 blur-3xl"></div>

        <div class="relative">
          <div class="mx-auto mb-6 inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-primary-vibrant/15 text-primary-vibrant">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>

          <h2 class="text-3xl font-extrabold text-white md:text-4xl">
            ¿Quieres aplicar estas estrategias en tu <span class="gradient-text">proyecto</span>?
          </h2>
          <p class="mx-auto mt-4 max-w-2xl text-slate-300">
            Te ayudamos a convertir estas ideas en resultados reales. Conversemos sobre tu proyecto.
          </p>
          <div class="mt-8 flex flex-col items-center justify-center gap-4 md:flex-row">
            <a
              href="/contacto"
              class="rounded-xl bg-gradient-to-r from-primary-vibrant to-accent px-8 py-4 font-bold text-white shadow-lg transition-all hover:scale-105 hover:shadow-primary-vibrant/25"
            >
              Impulsa tu Proyecto
            </a>
            <a
              href="/servicios"
              class="rounded-xl border border-white/20 px-8 py-4 font-semibold text-slate-200 transition-all hover:border-primary-vibrant/50 hover:text-primary-vibrant"
            >
              Explorar Servicios
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
