---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featuredPosts = posts.filter((post) => post.data.isFeatured);

const categories = [
  { name: 'Todos', icon: 'M4 6h16M4 12h16M4 18h16', count: posts.length },
  { name: 'UI/UX', icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.346l1.657-1.658a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01', count: posts.filter(p => p.data.tags.some(t => t.includes('UI') || t.includes('UX'))).length },
  { name: 'Conversión', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6', count: posts.filter(p => p.data.tags.some(t => t.includes('Conversión'))).length },
  { name: 'Ecommerce', icon: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z', count: posts.filter(p => p.data.tags.some(t => t.includes('Ecommerce'))).length },
];
---

<MainLayout title="Blog | Celeris Code" description="Artículos estratégicos sobre UI/UX, conversión, ecommerce y desarrollo de productos digitales de alto rendimiento.">
  <!-- Hero Section -->
  <section class="relative overflow-hidden py-20 md:py-28">
    <!-- Background decorations -->
    <div class="absolute left-0 top-0 h-96 w-96 -translate-x-1/2 -translate-y-1/2 rounded-full aurora-blue opacity-40 blur-3xl"></div>
    <div class="absolute right-0 top-40 h-80 w-80 translate-x-1/3 rounded-full aurora-purple opacity-30 blur-3xl"></div>

    <div class="container relative mx-auto px-6">
      <div class="mx-auto max-w-4xl">
        <span class="pill">Blog & Recursos</span>
        <h1 class="section-title mt-6">
          Insights para <span class="gradient-text">acelerar tu negocio digital</span>
        </h1>
        <p class="section-subtitle mt-5">
          Estrategias probadas de diseño, UX y desarrollo para equipos que buscan resultados medibles y experiencias web excepcionales.
        </p>
      </div>

      <!-- Featured Image -->
      <div class="mx-auto mt-12 max-w-5xl overflow-hidden rounded-3xl border border-white/10 shadow-2xl">
        <img
          src="https://images.unsplash.com/photo-1499750310107-5fef28a66643?auto=format&fit=crop&w=1200&q=80"
          alt="Blog de Celeris Code - Estrategias digitales"
          class="w-full object-cover opacity-90 transition-opacity hover:opacity-100"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Categories Section -->
  <section class="py-12">
    <div class="container mx-auto px-6">
      <div class="flex flex-wrap gap-4">
        {categories.map((cat) => (
          <div class="group inline-flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-5 py-3 backdrop-blur-xl transition-all hover:border-primary-vibrant/30 hover:bg-primary-vibrant/5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-slate-400 transition-colors group-hover:text-primary-vibrant" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d={cat.icon} />
            </svg>
            <span class="text-sm font-medium text-slate-300 group-hover:text-white">{cat.name}</span>
            <span class="rounded-full bg-white/10 px-2 py-0.5 text-xs font-semibold text-slate-400">{cat.count}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Posts -->
  {featuredPosts.length > 0 && (
    <section class="py-16">
      <div class="container mx-auto px-6">
        <div class="mb-10 flex items-end justify-between">
          <div>
            <div class="mb-3 inline-flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-vibrant" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
              </svg>
              <h2 class="text-2xl font-bold text-white">Artículos Destacados</h2>
            </div>
            <p class="text-slate-400">Lo más relevante para tu estrategia digital</p>
          </div>
        </div>

        <div class="grid gap-8 md:grid-cols-2">
          {featuredPosts.map((post) => (
            <article class="group bento-card">
              <div class="relative mb-6 overflow-hidden rounded-2xl">
                <img
                  src={post.data.cover}
                  alt={`Portada: ${post.data.title}`}
                  class="aspect-video w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
                <!-- Overlay gradient -->
                <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-primary-deep/60 via-transparent to-transparent"></div>
                <!-- Badge -->
                <div class="absolute left-4 top-4 flex gap-2">
                  <span class="rounded-lg bg-primary-vibrant/90 px-3 py-1.5 text-xs font-bold text-white">
                    {post.data.readingTime}
                  </span>
                  {post.data.isFeatured && (
                    <span class="rounded-lg bg-accent/90 px-3 py-1.5 text-xs font-bold text-white">
                      Destacado
                    </span>
                  )}
                </div>
              </div>

              <div class="flex flex-wrap gap-2">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="pill text-xs">{tag}</span>
                ))}
              </div>

              <h3 class="mt-4 text-2xl font-bold text-white group-hover:text-primary-vibrant transition-colors">
                {post.data.title}
              </h3>

              <p class="mt-3 text-sm leading-relaxed text-slate-300">{post.data.excerpt}</p>

              <div class="mt-6 flex items-center justify-between">
                <div class="flex items-center gap-3 text-xs text-slate-400">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                  <span>{post.data.author}</span>
                  <span class="mx-1">•</span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <span>{post.data.date.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                </div>

                <a href={`/blog/${post.id}`} class="inline-flex items-center gap-2 text-sm font-semibold text-primary-vibrant transition-all hover:gap-3 hover:text-sky-300">
                  Leer más
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- All Posts -->
  <section class="py-16">
    <div class="container mx-auto px-6">
      <div class="mb-10">
        <h2 class="mb-2 text-2xl font-bold text-white">Todos los Artículos</h2>
        <p class="text-slate-400">Guías completas sobre diseño, desarrollo y estrategia digital</p>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {posts.map((post) => (
          <article class="group bento-card">
            <div class="relative mb-5 overflow-hidden rounded-xl">
              <img
                src={post.data.cover}
                alt={`Portada: ${post.data.title}`}
                class="aspect-video w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute right-3 top-3">
                <span class="rounded-lg bg-primary-deep/90 px-2 py-1 text-xs font-semibold text-white backdrop-blur-sm">
                  {post.data.readingTime}
                </span>
              </div>
            </div>

            <div class="flex flex-wrap gap-2">
              {post.data.tags.slice(0, 2).map((tag) => (
                <span class="pill text-xs">{tag}</span>
              ))}
            </div>

            <h3 class="mt-3 text-lg font-bold text-white group-hover:text-primary-vibrant transition-colors">
              {post.data.title}
            </h3>

            <p class="mt-2 text-sm leading-relaxed text-slate-300">{post.data.excerpt}</p>

            <div class="mt-5 flex items-center justify-between">
              <span class="text-xs text-slate-400">
                {post.data.date.toLocaleDateString('es-ES', { year: 'numeric', month: 'long' })}
              </span>

              <a href={`/blog/${post.id}`} class="inline-flex items-center gap-2 text-sm font-semibold text-primary-vibrant transition-all hover:gap-3 hover:text-sky-300">
                Leer
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter/CTA Section -->
  <section class="py-20">
    <div class="container mx-auto px-6">
      <div class="bento-card-premium mx-auto max-w-5xl overflow-hidden p-8 text-center md:p-12">
        <!-- Background decorations -->
        <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full aurora-teal opacity-40 blur-3xl"></div>
        <div class="absolute -bottom-20 -left-20 h-64 w-64 rounded-full aurora-blue opacity-30 blur-3xl"></div>

        <div class="relative">
          <div class="mx-auto mb-6 inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-primary-vibrant/15 text-primary-vibrant">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>

          <h2 class="text-3xl font-extrabold text-white md:text-4xl">
            ¿Necesitas ayuda con tu <span class="gradient-text">proyecto digital</span>?
          </h2>
          <p class="mx-auto mt-4 max-w-2xl text-slate-300">
            Conversemos sobre cómo podemos transformar tu presencia web con estrategias probadas de UX y desarrollo moderno.
          </p>
          <div class="mt-8 flex flex-col items-center justify-center gap-4 md:flex-row">
            <a
              href="/contacto"
              class="rounded-xl bg-gradient-to-r from-primary-vibrant to-accent px-8 py-4 font-bold text-white shadow-lg transition-all hover:scale-105 hover:shadow-primary-vibrant/25"
            >
              Contactar Ahora
            </a>
            <a
              href="/servicios"
              class="rounded-xl border border-white/20 px-8 py-4 font-semibold text-slate-200 transition-all hover:border-primary-vibrant/50 hover:text-primary-vibrant"
            >
              Ver Servicios
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
