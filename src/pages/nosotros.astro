---
import MainLayout from '../layouts/MainLayout.astro';
import SectionTitle from '../components/ui/SectionTitle.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';

import { VALUE_PILLARS, PROCESS_STEPS, SITE_NAME } from '../lib/constants';
import { getServiceIcon } from '../lib/service-assets';

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: `Nosotros | ${SITE_NAME}`,
  description:
    'Visión, metodología y valores de Celeris Code para crear activos digitales de alto impacto.',
  url: '/nosotros',
};
---

<MainLayout title="Nosotros | Celeris Code" schema={aboutSchema}>
  <!-- Hero Section -->
  <section class="relative overflow-hidden py-24 md:py-32">
    <div class="pointer-events-none absolute inset-0 -z-20">
      <div class="aurora-blue absolute -left-[10%] top-[-10%] h-96 w-96 opacity-40"></div>
      <div class="aurora-purple absolute right-[-10%] top-[10%] h-80 w-80 opacity-30"></div>
    </div>

    <div class="container mx-auto px-6 text-center">
      <SectionTitle
        badge="Sobre Nosotros"
        title="Creamos experiencias que <span class='gradient-text'>impulsan negocios</span>"
        subtitle="Somos un equipo de diseñadores, desarrolladores y estrategas digitales comprometidos con transformar ideas en productos web de alto impacto."
        className="mb-12"
      />

      <div
        class="mx-auto max-w-5xl mt-16 rounded-3xl overflow-hidden border border-white/10 shadow-2xl relative group"
      >
        <img
          src="/assets/blog/minimalismo-conversion.jpg"
          alt="Equipo colaborando"
          class="w-full object-cover grayscale-[0.2] group-hover:grayscale-0 transition-all duration-700"
          loading="eager"
        />
        <div
          class="absolute inset-0 bg-gradient-to-t from-slate-950/60 via-transparent to-transparent"
        >
        </div>
      </div>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="py-24 bg-slate-900/20">
    <div class="container mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12 max-w-6xl mx-auto">
        <Card isPremium padding="lg">
          <Badge variant="accent" className="mb-6">Misión</Badge>
          <h2 class="text-3xl font-bold text-white mb-6">Transformar la presencia digital</h2>
          <p class="text-slate-300 leading-relaxed text-lg">
            Nuestra misión es ayudar a marcas ambiciosas a construir <strong class="text-white"
              >activos digitales de alto rendimiento</strong
            > que no solo se vean bien, sino que generen resultados medibles y confianza duradera.
          </p>
        </Card>

        <Card isPremium padding="lg">
          <Badge variant="accent" className="mb-6">Visión</Badge>
          <h2 class="text-3xl font-bold text-white mb-6">El socio tecnológico del futuro</h2>
          <p class="text-slate-300 leading-relaxed text-lg">
            Aspiramos a ser el referente en ejecución técnica y estrategia UX, donde la velocidad y
            la calidad convergen para crear el <strong class="text-white"
              >estándar de la industria</strong
            > en productos digitales.
          </p>
        </Card>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-24">
    <div class="container mx-auto px-6">
      <SectionTitle
        badge="Nuestros Valores"
        title="Principios que <span class='gradient-text'>guían cada decisión</span>"
        className="mb-16"
      />

      <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        {
          VALUE_PILLARS.map((pillar, index) => (
            <Card data-reveal style={`--reveal-delay: ${index * 100}ms`}>
              <div class="mb-6 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary-vibrant/10 text-primary-vibrant">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-6 w-6"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d={getServiceIcon(pillar.icon)}
                  />
                </svg>
              </div>
              <h3 class="text-xl font-bold text-white mb-4">{pillar.title}</h3>
              <p class="text-slate-300 text-sm leading-relaxed mb-6">{pillar.description}</p>
              <div class="flex flex-wrap gap-2">
                {pillar.tags.map((tag) => (
                  <Badge variant="outline">{tag}</Badge>
                ))}
              </div>
            </Card>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-24 bg-slate-900/30">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center max-w-6xl mx-auto">
        <div>
          <SectionTitle
            align="left"
            badge="Metodología"
            title="Cómo convertimos ideas en <span class='gradient-text'>realidad rentable</span>"
            subtitle="Un proceso iterativo diseñado para minimizar riesgos y maximizar el impacto en cada fase."
          />

          <div class="mt-12 space-y-8">
            {
              PROCESS_STEPS.map((step) => (
                <div class="flex gap-6 group">
                  <div class="flex-shrink-0 w-12 h-12 rounded-full border border-white/10 bg-white/5 flex items-center justify-center text-primary-vibrant font-black group-hover:border-primary-vibrant/50 transition-colors">
                    {step.id}
                  </div>
                  <div>
                    <h3 class="text-lg font-bold text-white mb-2">{step.title}</h3>
                    <p class="text-sm text-slate-300 leading-relaxed">{step.description}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <div class="relative">
          <div
            class="absolute inset-0 bg-gradient-to-tr from-primary-vibrant/20 to-accent/20 blur-3xl rounded-full"
          >
          </div>
          <Card padding="none" isPremium className="relative z-10">
            <img
              src="/assets/projects/posmart.png"
              alt="Caso real Celeris Code"
              class="w-full h-auto"
            />
          </Card>
        </div>
      </div>
    </div>
  </section>

  <FinalCTA />
</MainLayout>
