---
import MainLayout from '../layouts/MainLayout.astro';
import SectionTitle from '../components/ui/SectionTitle.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';

import { VALUE_PILLARS, PROCESS_STEPS, SITE_NAME } from '../lib/constants';
import { getServiceIcon } from '../lib/service-assets';
import { ICON_BY_SERVICE } from '../lib/site-config';

const aboutSchema = {
 '@context': 'https://schema.org',
 '@type': 'AboutPage',
 name: `Nosotros | ${SITE_NAME}`,
 description:
 'Visión, metodología y valores de Celeris Code para crear activos digitales de alto impacto.',
 url: '/nosotros',
};
---

<style>
  @keyframes dash {
    to {
      stroke-dashoffset: 0;
    }
  }
  .animate-dash {
    animation: dash 3s ease-out forwards;
  }
  
  .aurora-blue {
    background: radial-gradient(circle at center, var(--color-primary) 0%, transparent 70%);
    filter: blur(60px);
  }
  
  .aurora-purple {
    background: radial-gradient(circle at center, var(--color-accent) 0%, transparent 70%);
    filter: blur(60px);
  }
</style>

<MainLayout title="Nosotros | Celeris Code" schema={aboutSchema}>
 <!-- Hero Section -->
 <section class="relative overflow-hidden py-16 md:py-20">
 <div class="pointer-events-none absolute inset-0 -z-20">
 <div class="aurora-blue absolute -left-[10%] top-[-10%] h-96 w-96 opacity-40"></div>
 <div class="aurora-purple absolute right-[-10%] top-[10%] h-80 w-80 opacity-30"></div>
 </div>

 <div class="container mx-auto px-6 text-center">
 <SectionTitle
 badge="Sobre Nosotros"
 title="Creamos experiencias que <span class='gradient-text'>impulsan negocios</span>"
 subtitle="Somos un equipo de diseñadores, desarrolladores y estrategas digitales comprometidos con transformar ideas en productos web de alto impacto."
 className="mb-12"
 />

 <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 mt-16 max-w-6xl mx-auto">
      <!-- Image Hero Container (The Heart of the Bento) -->
      <div class="lg:col-span-8 group relative overflow-hidden rounded-3xl border border-border-subtle bg-slate-900 shadow-2xl h-[450px]">
        <!-- Placeholder / Loading State for your AI Image -->
        <div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 animate-pulse"></div>
        
        <img 
          src="/assets/brand/hero-nosotros.webp" 
          alt="Celeris Code Engineering Visual"
          class="absolute inset-0 w-full h-full object-cover opacity-0 group-hover:scale-105 transition-all duration-1000"
          onload="this.classList.remove('opacity-0'); this.classList.add('opacity-100')"
          onerror="this.src='https://placehold.co/1200x675/102a43/3b82f6?text=Engineering+Dominance'"
        />

        <!-- Overlay for readability -->
        <div class="absolute inset-0 bg-gradient-to-t from-slate-950/80 via-transparent to-transparent"></div>

        <div class="absolute bottom-8 left-8 text-left">
          <Badge variant="accent vibrant" className="mb-3">Arquitectura Elite</Badge>
          <p class="text-white font-bold text-3xl max-w-md leading-tight">Diseñamos el ADN técnico de las marcas líderes.</p>
        </div>
      </div>

      <!-- Statistics & Info Cards -->
      <div class="lg:col-span-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-6">
        <Card isPremium padding="lg" className="flex flex-col justify-center text-left border-primary/20 bg-primary/5">
          <div class="text-primary-vibrant font-black text-5xl mb-2 tracking-tighter">99.9%</div>
          <h4 class="text-text-primary font-bold text-lg">Disponibilidad</h4>
          <p class="text-text-secondary text-sm">Sistemas resilientes diseñados para no detenerse nunca.</p>
        </Card>
        
        <Card padding="lg" className="flex flex-col justify-center text-left group hover:border-accent/40 transition-colors">
          <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-accent/10 text-accent group-hover:scale-110 transition-transform">
             <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
             </svg>
          </div>
          <h4 class="text-text-primary font-bold text-lg">Velocidad Pura</h4>
          <p class="text-text-secondary text-sm">Optimizamos cada milisegundo para maximizar tu conversión.</p>
        </Card>
      </div>
    </div>
 </div>
 </section>

 <!-- Mission & Vision -->
 <section class="py-20 bg-bg-default">
 <div class="container mx-auto px-6">
 <div class="grid md:grid-cols-2 gap-12 max-w-6xl mx-auto">
 <Card isPremium padding="lg">
 <Badge variant="accent-vibrant" className="mb-6">Misión</Badge>
 <h2 class="text-3xl font-bold text-text-primary mb-6">Transformar la presencia digital</h2>
 <p class="text-text-secondary leading-relaxed text-lg">
 Nuestra misión es ayudar a marcas ambiciosas a construir <strong class="text-text-primary"
 >activos digitales de alto rendimiento</strong
 > que no solo se vean bien, sino que generen resultados medibles y confianza duradera.
 </p>
 </Card>

 <Card isPremium padding="lg">
 <Badge variant="accent-vibrant" className="mb-6">Visión</Badge>
 <h2 class="text-3xl font-bold text-text-primary mb-6">El socio tecnológico del futuro</h2>
 <p class="text-text-secondary leading-relaxed text-lg">
 Aspiramos a ser el referente en ejecución técnica y estrategia UX, donde la velocidad y
 la calidad convergen para crear el <strong class="text-text-primary"
 >estándar de la industria</strong
 > en productos digitales.
 </p>
 </Card>
 </div>
 </div>
 </section>

 <!-- Values -->
 <section class="py-20">
 <div class="container mx-auto px-6">
 <SectionTitle
 badge="Nuestros Valores"
 title="Principios que <span class='gradient-text'>guían cada decisión</span>"
 className="mb-16"
 />

 <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
 {
 VALUE_PILLARS.map((pillar, index) => (
 <Card data-reveal style={`--reveal-delay: ${index * 100}ms`}>
 <div class="mb-6 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary-vibrant/10 text-primary-vibrant">
 <svg
 xmlns="http://www.w3.org/2000/svg"
 class="h-6 w-6"
 fill="none"
 viewBox="0 0 24 24"
 stroke="currentColor"
 >
 <path
 stroke-linecap="round"
 stroke-linejoin="round"
 stroke-width="1.5"
 d={getServiceIcon(pillar.icon)}
 />
 </svg>
 </div>
 <h3 class="text-xl font-bold text-text-primary mb-4">{pillar.title}</h3>
 <p class="text-text-secondary text-sm leading-relaxed mb-6">{pillar.description}</p>
 <div class="flex flex-wrap gap-2">
 {pillar.tags.map((tag) => (
 <Badge variant="outline">{tag}</Badge>
 ))}
 </div>
 </Card>
 ))
 }
 </div>
 </div>
 </section>

 <!-- Process -->
 <section class="py-20 relative overflow-hidden">
 <div class="container mx-auto px-6">
   <div class="max-w-6xl mx-auto">
     <SectionTitle
       badge="Metodología"
       title="Cómo convertimos ideas en <span class='gradient-text'>realidad rentable</span>"
       subtitle="Un proceso iterativo diseñado para minimizar riesgos y maximizar el impacto en cada fase."
       className="mb-16"
     />

     <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
       {[
         { id: '01', title: 'Diagnóstico', icon: 'diagnose', desc: 'Analizamos objetivos, público y propuesta de valor priorizada.' },
         { id: '02', title: 'Arquitectura', icon: 'architecture', desc: 'Mapa de contenidos y flujo UX orientado a minimizar fricción.' },
         { id: '03', title: 'Diseño + Build', icon: 'build', desc: 'UI moderna con microanimaciones y rendimiento técnico sólido.' },
         { id: '04', title: 'Optimización', icon: 'optimization', desc: 'Lanzamiento e iteración continua basada en comportamiento real.' }
       ].map((step, index) => (
         <Card 
           padding="lg"
           className="relative group flex flex-col items-center text-center h-full" 
           data-reveal 
           style={`--reveal-delay: ${index * 150}ms`}
         >
           {/* Step number background bubble */}
           <div class="absolute -top-3 -right-3 w-12 h-12 rounded-full bg-bg-card border border-primary/20 shadow-md flex items-center justify-center text-lg font-black text-primary/80 group-hover:text-primary/80 group-hover:scale-110 transition-all duration-500 select-none shadow-sm">
             {step.id}
           </div>

           {/* Icon Container with Glass Effect */}
           <div class="mb-6 inline-flex h-14 w-14 items-center justify-center rounded-2xl backdrop-blur-md bg-primary/10 text-primary border border-primary/20 shadow-inner group-hover:bg-primary group-hover:text-white group-hover:rotate-6 transition-all duration-500">
             <svg
               xmlns="http://www.w3.org/2000/svg"
               class="h-7 w-7"
               fill="none"
               viewBox="0 0 24 24"
               stroke="currentColor"
             >
               <path
                 stroke-linecap="round"
                 stroke-linejoin="round"
                 stroke-width="1.5"
                 d={getServiceIcon(step.icon)}
               />
             </svg>
           </div>

           <h3 class="text-lg font-bold text-text-primary mb-3">{step.title}</h3>
           <p class="text-xs text-text-secondary leading-relaxed">{step.desc}</p>
         </Card>
       ))}
     </div>
   </div>
 </div>
 </section>

 <FinalCTA />
</MainLayout>
