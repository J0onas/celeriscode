---
import MainLayout from '../layouts/MainLayout.astro';
---

<!-- 
  Netlify static form detection
  This hidden form is rendered at build time so Netlify detects it
-->
<form name="contacto" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/contacto/exito/" class="hidden" aria-hidden="true" data-netlify-form>
  <input type="hidden" name="form-name" value="contacto" />
  <input name="bot-field" />
  <input name="name" />
  <input name="email" />
  <input name="company" />
  <select name="service"><option>landing-page</option></select>
  <select name="budget"><option>1500-3000</option></select>
  <textarea name="message"></textarea>
  <select name="source"><option>google</option></select>
</form>

<MainLayout title="Contacto | Celeris Code" description="Conversemos sobre tu próximo proyecto digital: landing page, multipage, ecommerce o SaaS. Respuesta en menos de 24 horas.">
  <!-- Hero Section -->
  <section class="relative overflow-hidden py-20 md:py-28">
    <!-- Background decorations -->
    <div class="absolute left-0 top-0 h-96 w-96 -translate-x-1/2 -translate-y-1/2 rounded-full aurora-blue opacity-40 blur-3xl"></div>
    <div class="absolute right-0 top-40 h-80 w-80 translate-x-1/3 rounded-full aurora-purple opacity-30 blur-3xl"></div>

    <div class="container relative mx-auto px-6">
      <div class="mx-auto max-w-4xl text-center">
        <span class="pill">Contacto</span>
        <h1 class="section-title mt-6">
          Hagamos realidad tu <span class="gradient-text">próximo proyecto digital</span>
        </h1>
        <p class="section-subtitle mt-5">
          Cuéntanos tu idea y te proponemos un enfoque claro de diseño y desarrollo. Respuesta garantizada en menos de 24 horas.
        </p>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-12">
    <div class="container mx-auto px-6">
      <div class="grid gap-12 lg:grid-cols-5">
        <!-- Left Column: Info -->
        <div class="lg:col-span-2">
          <!-- Response Time Badge -->
          <div class="mb-8 rounded-2xl border border-success/30 bg-success/10 p-5 backdrop-blur-xl">
            <div class="flex items-center gap-3">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-success/20 text-success">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-bold text-white">Respuesta rápida</p>
                <p class="text-xs text-slate-300">Te contactamos en menos de 24h</p>
              </div>
            </div>
          </div>

          <!-- Contact Info Cards -->
          <div class="space-y-5">
            <!-- Email -->
            <div class="group bento-card">
              <div class="flex items-start gap-4">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary-vibrant/10 text-primary-vibrant transition-colors group-hover:bg-primary-vibrant/20">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div class="flex-1">
                  <p class="text-sm font-medium text-slate-400">Email</p>
                  <a href="mailto:zorrillalucajhonathan@gmail.com" class="mt-1 text-base font-bold text-white transition-colors hover:text-primary-vibrant">
                    zorrillalucajhonathan@gmail.com
                  </a>
                </div>
              </div>
            </div>

            <!-- WhatsApp -->
            <div class="group bento-card">
              <div class="flex items-start gap-4">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-success/10 text-success transition-colors group-hover:bg-success/20">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                </div>
                <div class="flex-1">
                  <p class="text-sm font-medium text-slate-400">WhatsApp</p>
                  <a href="https://wa.me/51999999999" target="_blank" rel="noopener noreferrer" class="mt-1 text-base font-bold text-white transition-colors hover:text-success">
                    +51 999 999 999
                  </a>
                  <p class="mt-1 text-xs text-slate-400">Respuesta directa y rápida</p>
                </div>
              </div>
            </div>

            <!-- Location -->
            <div class="group bento-card">
              <div class="flex items-start gap-4">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-accent/10 text-accent transition-colors group-hover:bg-accent/20">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div class="flex-1">
                  <p class="text-sm font-medium text-slate-400">Ubicación</p>
                  <p class="mt-1 text-base font-bold text-white">Lima, Perú</p>
                  <p class="text-sm text-slate-400">Remoto global — trabajamos con clientes de cualquier país</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Services Tags -->
          <div class="mt-8 bento-card">
            <p class="text-sm font-semibold uppercase tracking-wide text-slate-400">Servicios principales</p>
            <div class="mt-4 flex flex-wrap gap-2">
              <span class="pill">Landing Page</span>
              <span class="pill">Multipage</span>
              <span class="pill">Ecommerce</span>
              <span class="pill">SaaS</span>
            </div>
          </div>

          <!-- Trust Signal -->
          <div class="mt-8 overflow-hidden rounded-3xl border border-white/10 shadow-xl">
            <img
              src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?auto=format&fit=crop&w=600&q=80"
              alt="Equipo de Celeris Code trabajando"
              class="w-full object-cover opacity-90"
              loading="lazy"
            />
            <div class="bg-white/5 p-5 backdrop-blur-xl">
              <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary-vibrant/20 text-primary-vibrant">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-bold text-white">Proceso transparente</p>
                  <p class="text-xs text-slate-300">Sabrás cada paso del camino</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Column: Form -->
        <div class="lg:col-span-3">
          <div class="bento-card p-8 md:p-10">
            <div class="mb-8">
              <div class="mb-4 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-r from-primary-vibrant to-accent text-white">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                </svg>
              </div>
              <h2 class="text-2xl font-bold text-white md:text-3xl">Cuéntanos sobre tu proyecto</h2>
              <p class="mt-2 text-sm text-slate-300">
                Completa el formulario y te contactaremos para definir alcance, tiempos y próximos pasos.
              </p>
            </div>

            <form
              id="contact-form"
              class="space-y-6"
              name="contacto"
              method="POST"
              netlify-honeypot="bot-field"
            >
              <input type="hidden" name="form-name" value="contacto" />
              <p class="hidden">
                <label>No llenes esto: <input name="bot-field" /></label>
              </p>

              <!-- Name & Email Row -->
              <div class="grid gap-5 md:grid-cols-2">
                <div>
                  <label for="name" class="mb-2 block text-sm font-medium text-slate-200">
                    Nombre completo <span class="text-primary-vibrant">*</span>
                  </label>
                  <input
                    id="name"
                    name="name"
                    type="text"
                    class="w-full rounded-xl border border-white/15 bg-slate-950/70 px-4 py-3 text-slate-100 placeholder-slate-500 outline-none transition-all focus:border-primary-vibrant focus:ring-2 focus:ring-primary-vibrant/20"
                    placeholder="Ej: María López"
                    required
                  />
                </div>

                <div>
                  <label for="email" class="mb-2 block text-sm font-medium text-slate-200">
                    Email <span class="text-primary-vibrant">*</span>
                  </label>
                  <input
                    id="email"
                    name="email"
                    type="email"
                    class="w-full rounded-xl border border-white/15 bg-slate-950/70 px-4 py-3 text-slate-100 placeholder-slate-500 outline-none transition-all focus:border-primary-vibrant focus:ring-2 focus:ring-primary-vibrant/20"
                    placeholder="maria@empresa.com"
                    required
                  />
                </div>
              </div>

              <!-- Company & Service Row -->
              <div class="grid gap-5 md:grid-cols-2">
                <div>
                  <label for="company" class="mb-2 block text-sm font-medium text-slate-200">
                    Empresa o marca
                  </label>
                  <input
                    id="company"
                    name="company"
                    type="text"
                    class="w-full rounded-xl border border-white/15 bg-slate-950/70 px-4 py-3 text-slate-100 placeholder-slate-500 outline-none transition-all focus:border-primary-vibrant focus:ring-2 focus:ring-primary-vibrant/20"
                    placeholder="Ej: TechStartup"
                  />
                </div>

                <div>
                  <label for="service" class="mb-2 block text-sm font-medium text-slate-200">
                    Tipo de proyecto <span class="text-primary-vibrant">*</span>
                  </label>
                  <select
                    id="service"
                    name="service"
                    class="w-full rounded-xl border border-white/15 bg-slate-950/70 px-4 py-3 text-slate-100 outline-none transition-all focus:border-primary-vibrant focus:ring-2 focus:ring-primary-vibrant/20"
                    required
                  >
                    <option value="">Selecciona una opción</option>
                    <option value="landing-page">Landing Page</option>
                    <option value="multipage">Sitio Multipage</option>
                    <option value="ecommerce">Ecommerce</option>
                    <option value="saas">Plataforma SaaS</option>
                    <option value="not-sure">No estoy seguro/a</option>
                  </select>
                </div>
              </div>

              <!-- Budget -->
              <div>
                <label for="budget" class="mb-2 block text-sm font-medium text-slate-200">
                  Presupuesto estimado
                </label>
                <select
                  id="budget"
                  name="budget"
                  class="w-full rounded-xl border border-white/15 bg-slate-950/70 px-4 py-3 text-slate-100 outline-none transition-all focus:border-primary-vibrant focus:ring-2 focus:ring-primary-vibrant/20"
                >
                  <option value="">Selecciona un rango</option>
                  <option value="500-1500">$500 - $1,500 USD</option>
                  <option value="1500-3000">$1,500 - $3,000 USD</option>
                  <option value="3000-5000">$3,000 - $5,000 USD</option>
                  <option value="5000+">$5,000+ USD</option>
                  <option value="discuss">Prefiero discutirlo</option>
                </select>
              </div>

              <!-- Message -->
              <div>
                <label for="message" class="mb-2 block text-sm font-medium text-slate-200">
                  Describe tu proyecto <span class="text-primary-vibrant">*</span>
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  class="w-full resize-none rounded-xl border border-white/15 bg-slate-950/70 px-4 py-3 text-slate-100 placeholder-slate-500 outline-none transition-all focus:border-primary-vibrant focus:ring-2 focus:ring-primary-vibrant/20"
                  placeholder="Cuéntanos: ¿qué necesitas? Ejemplo: 'Quiero una landing page para vender mi curso online. Mi público son emprendedores de Latinoamérica. Necesito integraciones con pasarela de pago.'"
                  required
                ></textarea>
                <p class="mt-2 text-xs text-slate-500">
                  Mientras más detalles compartas, mejor podremos asesorarte.
                </p>
              </div>

              <!-- How did you find us -->
              <div>
                <label for="source" class="mb-2 block text-sm font-medium text-slate-200">
                  ¿Cómo nos encontraste?
                </label>
                <select
                  id="source"
                  name="source"
                  class="w-full rounded-xl border border-white/15 bg-slate-950/70 px-4 py-3 text-slate-100 outline-none transition-all focus:border-primary-vibrant focus:ring-2 focus:ring-primary-vibrant/20"
                >
                  <option value="">Selecciona una opción</option>
                  <option value="google">Google</option>
                  <option value="social">Redes sociales</option>
                  <option value="referral">Recomendación</option>
                  <option value="blog">Blog o artículo</option>
                  <option value="other">Otro</option>
                </select>
              </div>

              <!-- Submit Button -->
              <button
                type="submit"
                class="group flex w-full items-center justify-center gap-3 rounded-xl bg-gradient-to-r from-primary-vibrant to-accent py-4 text-lg font-bold text-white shadow-lg transition-all hover:scale-[1.02] hover:shadow-primary-vibrant/30"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                Enviar solicitud
              </button>

              <p class="text-center text-xs text-slate-500">
                Al enviar, aceptas nuestra política de privacidad. No compartimos tus datos con terceros.
              </p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="py-20">
    <div class="container mx-auto px-6">
      <div class="mx-auto max-w-4xl text-center">
        <span class="pill">Proceso</span>
        <h2 class="section-title mt-6">Qué pasa después de contactarnos</h2>
        <p class="section-subtitle mt-4">
          Un proceso claro y sin sorpresas para que sepas exactamente qué esperar.
        </p>
      </div>

      <div class="mx-auto mt-12 grid max-w-5xl gap-6 md:grid-cols-4">
        <!-- Step 1 -->
        <div class="group bento-card text-center">
          <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-primary-vibrant/10 text-2xl font-black text-primary-vibrant transition-all group-hover:bg-primary-vibrant/20">
            1
          </div>
          <h3 class="text-lg font-bold text-white">Contacto recibido</h3>
          <p class="mt-2 text-sm text-slate-300">
            Revisamos tu solicitud y te respondemos en menos de 24 horas.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="group bento-card text-center">
          <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-accent/10 text-2xl font-black text-accent transition-all group-hover:bg-accent/20">
            2
          </div>
          <h3 class="text-lg font-bold text-white">Llamada de diagnóstico</h3>
          <p class="mt-2 text-sm text-slate-300">
            Conversamos 20-30 min para entender tu objetivo, público y presupuesto.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="group bento-card text-center">
          <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-success/10 text-2xl font-black text-success transition-all group-hover:bg-success/20">
            3
          </div>
          <h3 class="text-lg font-bold text-white">Propuesta detallada</h3>
          <p class="mt-2 text-sm text-slate-300">
            Te enviamos alcance, timeline, inversión y entregables claros.
          </p>
        </div>

        <!-- Step 4 -->
        <div class="group bento-card text-center">
          <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-primary-vibrant/10 text-2xl font-black text-primary-vibrant transition-all group-hover:bg-primary-vibrant/20">
            4
          </div>
          <h3 class="text-lg font-bold text-white">Inicio del proyecto</h3>
          <p class="mt-2 text-sm text-slate-300">
            Comenzamos con un kickoff y sprints semanales con avances visibles.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20">
    <div class="container mx-auto px-6">
      <div class="mx-auto max-w-4xl">
        <div class="mb-10 text-center">
          <span class="pill">FAQ</span>
          <h2 class="section-title mt-6">Preguntas frecuentes</h2>
          <p class="section-subtitle mt-4">
            Respuestas rápidas a las dudas más comunes antes de empezar un proyecto.
          </p>
        </div>

        <div class="space-y-4">
          <!-- FAQ 1 -->
          <details class="group bento-card cursor-pointer">
            <summary class="flex items-center justify-between text-white">
              <h3 class="text-lg font-bold">¿Cuánto tiempo toma un proyecto típico?</h3>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-vibrant transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-4 text-sm leading-relaxed text-slate-300">
              Depende del alcance: una landing page toma 1-2 semanas, un sitio multipage 3-4 semanas, un ecommerce 4-6 semanas y un SaaS 6-12 semanas. Cada proyecto es único y lo definimos juntos en la propuesta.
            </p>
          </details>

          <!-- FAQ 2 -->
          <details class="group bento-card cursor-pointer">
            <summary class="flex items-center justify-between text-white">
              <h3 class="text-lg font-bold">¿Trabajan con clientes de otros países?</h3>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-vibrant transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-4 text-sm leading-relaxed text-slate-300">
              Sí, somos 100% remotos. Trabajamos con clientes de Latinoamérica, España y Estados Unidos. Nos adaptamos a tu zona horaria y nos comunicamos por WhatsApp, email o videollamada.
            </p>
          </details>

          <!-- FAQ 3 -->
          <details class="group bento-card cursor-pointer">
            <summary class="flex items-center justify-between text-white">
              <h3 class="text-lg font-bold">¿Cómo es el proceso de pago?</h3>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-vibrant transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-4 text-sm leading-relaxed text-slate-300">
              Típicamente 50% al inicio y 50% al entregar. Para proyectos más grandes, dividimos en hitos mensuales. Aceptamos transferencia bancaria, PayPal y Wise.
            </p>
          </details>

          <!-- FAQ 4 -->
          <details class="group bento-card cursor-pointer">
            <summary class="flex items-center justify-between text-white">
              <h3 class="text-lg font-bold">¿Qué incluye el soporte post-lanzamiento?</h3>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-vibrant transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-4 text-sm leading-relaxed text-slate-300">
              Incluimos 30 días de soporte gratuito para bugs y ajustes menores. Después, ofrecemos planes mensuales de mantenimiento que incluyen actualizaciones, backups y mejoras continuos.
            </p>
          </details>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20">
    <div class="container mx-auto px-6">
      <div class="bento-card-premium mx-auto max-w-5xl overflow-hidden p-8 text-center md:p-12">
