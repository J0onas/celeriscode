---
import MainLayout from '../../layouts/MainLayout.astro';
import { getWhatsAppUrl } from '../../lib/site-config';

const whatsappUrl = getWhatsAppUrl(
 'Hola Celeris Code, acabo de enviar el formulario y deseo seguimiento.'
);
const successSchema = {
 '@context': 'https://schema.org',
 '@type': 'WebPage',
 name: 'Gracias por contactarnos',
 url: '/contacto/exito',
};
---

<MainLayout
 title="Mensaje Enviado | Celeris Code"
 description="Hemos recibido tu mensaje. Te contactaremos en menos de 24 horas."
 schema={successSchema}
>
 <section class="container mx-auto px-6 py-16 md:py-24">
 <div class="mx-auto max-w-2xl text-center">
 <!-- Success Icon -->
 <div
 class="mx-auto mb-8 flex h-24 w-24 items-center justify-center rounded-full bg-success/20 text-success"
 >
 <svg
 xmlns="http://www.w3.org/2000/svg"
 class="h-12 w-12"
 fill="none"
 viewBox="0 0 24 24"
 stroke="currentColor"
 stroke-width="2"
 >
 <path
 stroke-linecap="round"
 stroke-linejoin="round"
 d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
 </svg>
 </div>

 <h1 class="section-title">¡Mensaje enviado con éxito!</h1>

 <p class="mt-6 text-lg text-text-secondary">
 Hemos recibido tu solicitud correctamente. Nuestro equipo la revisará y te contactará en <strong
 class="text-text-primary">menos de 24 horas</strong
 >.
 </p>

 <div class="mt-10 bento-card-premium p-8">
 <div class="flex items-center gap-4">
 <div
 class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary-vibrant/10 text-primary-vibrant"
 >
 <svg
 xmlns="http://www.w3.org/2000/svg"
 class="h-6 w-6"
 fill="none"
 viewBox="0 0 24 24"
 stroke="currentColor"
 stroke-width="2"
 >
 <path
 stroke-linecap="round"
 stroke-linejoin="round"
 d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
 </svg>
 </div>
 <div class="text-left">
 <p class="text-sm font-bold text-text-primary">¿Qué sigue?</p>
 <p class="text-sm text-text-secondary">
 Revisamos tu solicitud → Te contactamos → Definimos alcance y tiempos
 </p>
 </div>
 </div>
 </div>

 <div class="mt-8 flex flex-col items-center justify-center gap-4 md:flex-row">
 <a
 href="/"
 class="rounded-xl bg-gradient-to-r from-primary-vibrant to-accent px-8 py-4 font-bold text-text-primary shadow-lg transition-all hover:scale-105"
 >
 Volver al Inicio
 </a>
 <a
 href="/blog"
 class="rounded-xl border border-border-subtle px-8 py-4 font-semibold text-text-secondary transition-all hover:border-primary-vibrant/50 hover:text-primary-vibrant"
 >
 Explorar el Blog
 </a>
 </div>

 <p class="mt-8 text-sm text-text-secondary">
 ¿Necesitas respuesta inmediata? <a
 href={whatsappUrl}
 target="_blank"
 rel="noopener noreferrer"
 data-track="contact_whatsapp_click"
 data-track-location="success"
 class="text-success underline">Escríbenos por WhatsApp</a
 >
 </p>
 </div>
 </section>
</MainLayout>
