---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/sections/Hero.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import SectionTitle from '../components/ui/SectionTitle.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';

import { PROJECT_TYPE_LABEL, SITE_NAME } from '../lib/site-config';
import { getOrderedPortfolioCases } from '../lib/content-helpers';
import { SERVICE_HOME_MEDIA, getServiceIcon } from '../lib/service-assets';
import { PROCESS_STEPS, VALUE_PILLARS, SITE_DEFAULTS } from '../lib/constants';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);

const cases = (await getCollection('cases')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const portfolioCases = getOrderedPortfolioCases(cases);

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const latestPosts = allPosts.slice(0, 3);

const homeSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: `Inicio | ${SITE_NAME}`,
  description: SITE_DEFAULTS.description,
};
---

<MainLayout schema={homeSchema}>
  <Hero showBento={true} />

  <!-- Trust Section -->
  <section class="py-12 bg-slate-950/50">
    <div class="container mx-auto px-6">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          VALUE_PILLARS.map((item, index) => (
            <Card data-reveal style={`--reveal-delay: ${index * 100}ms`}>
              <div class="inline-flex h-12 w-12 items-center justify-center rounded-2xl border border-primary-vibrant/30 bg-primary-vibrant/10 text-primary-vibrant mb-6">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-6 w-6"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d={getServiceIcon(item.icon)}
                  />
                </svg>
              </div>
              <h3 class="text-xl font-bold text-white mb-3">{item.title}</h3>
              <p class="text-sm text-slate-300 leading-relaxed">{item.description}</p>
            </Card>
          ))
        }

        <Card
          isPremium
          className="flex flex-col justify-center text-center border-primary-vibrant/20"
        >
          <p class="text-4xl font-black text-white">5+</p>
          <p class="text-xs uppercase tracking-widest text-primary-vibrant mt-2">Casos de éxito</p>
        </Card>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-24 relative" id="servicios">
    <div class="container mx-auto px-6">
      <SectionTitle
        badge="Nuestros Servicios"
        title="Construimos activos digitales de <span class='gradient-text'>alto rendimiento</span>"
        subtitle="No hacemos webs, construimos herramientas comerciales diseñadas para convertir visitas en ingresos."
        className="mb-16"
      />

      <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-4">
        {
          services.map((service, index) => {
            const media = SERVICE_HOME_MEDIA[service.id as keyof typeof SERVICE_HOME_MEDIA];
            return (
              <Card padding="none" data-reveal style={`--reveal-delay: ${index * 100}ms`}>
                <div class="aspect-video w-full overflow-hidden border-b border-white/10">
                  <img
                    src={media?.image ?? '/assets/projects/posmart.png'}
                    alt={media?.alt ?? service.data.title}
                    width={400}
                    height={225}
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                    loading="lazy"
                  />
                </div>
                <div class="p-6">
                  <Badge variant="accent" className="mb-4">
                    {media?.focus}
                  </Badge>
                  <h3 class="text-xl font-bold text-white mb-3">{service.data.title}</h3>
                  <p class="text-sm text-slate-300 leading-relaxed mb-6">
                    {service.data.description}
                  </p>
                  <Button
                    href={`/servicios/${service.id}`}
                    variant="ghost"
                    size="sm"
                    className="p-0 hover:bg-transparent hover:text-primary-vibrant"
                  >
                    Saber más &rarr;
                  </Button>
                </div>
              </Card>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- Portfolio Section -->
  <section class="py-24 bg-slate-900/30">
    <div class="container mx-auto px-6">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16">
        <SectionTitle
          align="left"
          badge="Portafolio"
          title="Resultados que <span class='gradient-text'>hablan por nosotros</span>"
          subtitle="Explora nuestras implementaciones reales en diversos sectores."
          className="max-w-2xl"
        />
        <Button href="/portafolio" variant="secondary">Ver todos los casos</Button>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {
          portfolioCases.slice(0, 3).map((item, index) => (
            <Card padding="none" data-reveal style={`--reveal-delay: ${index * 100}ms`}>
              <div class="aspect-video w-full overflow-hidden border-b border-white/10">
                <img
                  src={item.data.image}
                  alt={item.data.title}
                  width={600}
                  height={337}
                  class="h-full w-full object-cover"
                  loading="lazy"
                />
              </div>
              <div class="p-6">
                <div class="flex gap-2 mb-4">
                  <Badge variant="outline">{PROJECT_TYPE_LABEL[item.data.projectType]}</Badge>
                </div>
                <h3 class="text-xl font-bold text-white mb-2">{item.data.title}</h3>
                <p class="text-sm text-slate-300 line-clamp-2 mb-6">{item.data.summary}</p>
                <Button
                  href={item.data.url}
                  target="_blank"
                  variant="outline"
                  size="sm"
                  className="w-full"
                >
                  Visitar sitio
                </Button>
              </div>
            </Card>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="py-24">
    <div class="container mx-auto px-6">
      <SectionTitle
        badge="Metodología"
        title="Un proceso diseñado para la <span class='gradient-text'>velocidad y calidad</span>"
        className="mb-16"
      />

      <div class="grid gap-8 md:grid-cols-4">
        {
          PROCESS_STEPS.map((step, index) => (
            <div class="relative group" data-reveal style={`--reveal-delay: ${index * 100}ms`}>
              <div class="mb-6 text-5xl font-black text-white/5 group-hover:text-primary-vibrant/10 transition-colors duration-500">
                {step.id}
              </div>
              <h3 class="text-xl font-bold text-white mb-3">{step.title}</h3>
              <p class="text-sm text-slate-300 leading-relaxed">{step.description}</p>
              {index < PROCESS_STEPS.length - 1 && (
                <div class="hidden md:block absolute top-12 -right-4 w-8 h-px bg-white/10" />
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Blog Section -->
  <section class="py-24 bg-slate-900/30">
    <div class="container mx-auto px-6">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16">
        <SectionTitle
          align="left"
          badge="Blog"
          title="Insights para <span class='gradient-text'>crecer</span>"
          className="max-w-2xl"
        />
        <Button href="/blog" variant="secondary">Ir al blog</Button>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        {latestPosts.map((post) => (
          <a href={`/blog/${post.id}`} class="group">
            <Card padding="none" className="h-full">
              <div class="aspect-video w-full overflow-hidden border-b border-white/10">
                <img
                  src={post.data.cover}
                  alt={post.data.title}
                  width={500}
                  height={280}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <div class="p-6">
                <h3 class="text-lg font-bold text-white mb-3 group-hover:text-primary-vibrant transition-colors">
                  {post.data.title}
                </h3>
                <p class="text-sm text-slate-300 line-clamp-2">{post.data.excerpt}</p>
              </div>
            </Card>
          </a>
        ))}
      </div>
    </div>
  </section>

  <FinalCTA />
</MainLayout>
