---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/sections/Hero.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import SectionTitle from '../components/ui/SectionTitle.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';
import FAQ from '../components/sections/FAQ.astro';

import { PROJECT_TYPE_LABEL, SITE_NAME } from '../lib/site-config';
import { getOrderedPortfolioCases } from '../lib/content-helpers';
import { SERVICE_HOME_MEDIA, getServiceIcon } from '../lib/service-assets';
import { PROCESS_STEPS, VALUE_PILLARS, SITE_DEFAULTS } from '../lib/constants';

// Import project images for Astro Image optimization
import posmartImg from '../assets/projects/posmart.webp';
import bambinoImg from '../assets/projects/bambino.webp';
import inperuImg from '../assets/projects/inperu.webp';
import turquesaImg from '../assets/projects/turquesa.webp';
import zoibeautyImg from '../assets/projects/zoibeauty.webp';

// Import blog/service images
import landingImg from '../assets/blog/landing-conversion.webp';
import multipageImg from '../assets/projects/turquesa.webp';
import ecommerceImg from '../assets/blog/ecommerce-whatsapp.webp';
import saasImg from '../assets/projects/posmart.webp';

const imageMap: Record<string, any> = {
  'posmart.webp': posmartImg,
  'bambino.webp': bambinoImg,
  'inperu.webp': inperuImg,
  'turquesa.webp': turquesaImg,
  'zoibeauty.webp': zoibeautyImg,
  'landing-conversion.webp': landingImg,
  'ecommerce-whatsapp.webp': ecommerceImg,
};

// Helper to get optimized image
const getOptimizedImage = (path: string | undefined) => {
  if (!path) return posmartImg;
  const fileName = path.split('/').pop() || '';
  return imageMap[fileName] || posmartImg;
};

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);

const cases = (await getCollection('cases')).sort(
 (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const portfolioCases = getOrderedPortfolioCases(cases);

const allPosts = (await getCollection('blog')).sort(
 (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const latestPosts = allPosts.slice(0, 3);

const BRAND_ICONS: Record<string, string> = {
  Astro: `<svg class="w-3 h-3 mr-1.5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.8 19.7l-5.6-14.2c-.3-.8-1.5-.8-1.8 0L5.8 19.7c-.3.8.5 1.5 1.2 1.1l5.4-3.1c.4-.2.8-.2 1.2 0l5.4 3.1c.7.4 1.5-.3 1.2-1.1zM11.6 15l-1.3-3.2c-.2-.5.5-.9.9-.5l2 2c.3.3.1.8-.3.8h-1.3z"/></svg>`,
  React: `<svg class="w-3 h-3 mr-1.5" viewBox="-11.5 -10.23177 23 20.46354" fill="none" stroke="currentColor" stroke-width="1"><circle r="2.05" fill="currentColor"/><g><ellipse rx="11" ry="4.2"/><ellipse rx="11" ry="4.2" transform="rotate(60)"/><ellipse rx="11" ry="4.2" transform="rotate(120)"/></g></svg>`,
  Tailwind: `<svg class="w-3 h-3 mr-1.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12.001 4.8c-3.2 0-5.2 1.6-6 4.8 1.2-1.6 2.6-2.2 4.2-1.8 1.313.328 2.251 1.274 3.29 2.323C15.196 11.854 16.711 13.4 20.002 13.4c3.2 0 5.2-1.6 6-4.8-1.2 1.6-2.6 2.2-4.2 1.8-1.313-.328-2.251-1.274-3.29-2.323-1.706-1.727-3.221-3.277-6.511-3.277zm-6 8.6c-3.2 0-5.2 1.6-6 4.8 1.2-1.6 2.6-2.2 4.2-1.8 1.313.328 2.251 1.274 3.289 2.323 1.707 1.727 3.222 3.277 6.512 3.277 3.2 0 5.2-1.6 6-4.8-1.2 1.6-2.6 2.2-4.2 1.8-1.313-.328-2.251-1.274-3.289-2.323-1.707-1.727-3.222-3.277-6.512-3.277z"/></svg>`
};

const homeSchema = {
 '@context': 'https://schema.org',
 '@type': 'WebPage',
 name: `Inicio | ${SITE_NAME}`,
 description: SITE_DEFAULTS.description,
};
---

<MainLayout schema={homeSchema}>
 <Hero />

 {/* Scroll Indicator */}
 <div class="flex justify-center -mt-12 mb-12 animate-bounce">
   <div class="w-6 h-10 rounded-full border-2 border-primary/20 flex justify-center p-1">
     <div class="w-1.5 h-1.5 rounded-full bg-primary animate-scroll"></div>
   </div>
 </div>

 <!-- Authority Section -->
 <section class="py-20 bg-bg-default relative overflow-hidden">
   <div class="container mx-auto px-6">
     <div class="grid lg:grid-cols-2 gap-16 items-center">
       <div data-reveal>
         <Badge variant="primary-vibrant" className="mb-4">Ingeniería de Élite</Badge>
         <h2 class="text-4xl md:text-5xl font-black text-text-primary mb-6 leading-tight">
           Diseñamos el futuro de tu <span class="gradient-text">negocio digital</span>
         </h2>
         <p class="text-lg text-text-secondary mb-8 leading-relaxed">
           Combinamos metodologías ágiles con las tecnologías más disruptivas del mercado para crear activos que no solo funcionan, sino que dominan su categoría.
         </p>
         <div class="flex flex-wrap gap-4">
           <div class="flex items-center gap-3 px-4 py-2 rounded-xl bg-bg-card border border-border-subtle shadow-elegant group/item">
             <div class="text-primary-vibrant">
               <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={getServiceIcon('optimization')} />
               </svg>
             </div>
             <div>
               <p class="text-sm font-bold text-text-primary">Velocidad</p>
               <p class="text-[10px] text-text-secondary">Core Web Vitals A+</p>
             </div>
           </div>
           <div class="flex items-center gap-3 px-4 py-2 rounded-xl bg-bg-card border border-border-subtle shadow-elegant group/item">
             <div class="text-accent">
               <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={getServiceIcon('spark')} />
               </svg>
             </div>
             <div>
               <p class="text-sm font-bold text-text-primary">Conversión</p>
               <p class="text-[10px] text-text-secondary">UX centrada en ventas</p>
             </div>
           </div>
         </div>
       </div>

       {/* IMAGE PLACEHOLDER: Engineering Team / Dashboard */}
       <div class="relative group" data-reveal style="--reveal-delay: 200ms">
         <div class="absolute inset-0 bg-primary/20 blur-[120px] rounded-full opacity-30 group-hover:opacity-50 transition-opacity"></div>
         <div class="relative aspect-square md:aspect-video rounded-3xl overflow-hidden border border-border-subtle bg-bg-card shadow-elegant hover-lift">
            <Image 
              src={saasImg}
              alt="Dashboard de alto rendimiento"
              width={800}
              height={450}
              class="w-full h-full object-cover transition-opacity duration-700"
            />
         </div>
       </div>
     </div>
   </div>
 </section> 

 <section class="py-20 md:py-32 bg-bg-default relative z-10">
 <div class="container mx-auto px-6">
   <div class="mb-16 md:mb-24 text-center max-w-3xl mx-auto" data-reveal>
     <Badge variant="primary-vibrant" className="mb-4">ADN Celeris</Badge>
     <h2 class="text-4xl md:text-5xl font-black text-text-primary mb-6 tracking-tight">¿Por qué <span class="gradient-text">confiar en nosotros</span>?</h2>
     <p class="text-lg text-text-secondary leading-relaxed">Nuestra metodología combina rigor técnico, comunicación transparente y un enfoque obsesivo en escalar tus métricas de negocio.</p>
   </div>

   <div class="grid grid-cols-1 md:grid-cols-3 gap-6 auto-rows-[minmax(280px,auto)]">
     {
       VALUE_PILLARS.map((item, index) => {
         // Hacemos que la primera tarjeta sea más grande (Bento Grid style)
         const isLarge = index === 0;
         return (
           <Card 
             isPremium={isLarge}
             className={`group relative overflow-hidden flex flex-col justify-between ${isLarge ? 'md:col-span-2' : 'col-span-1'}`}
             data-reveal 
             style={`--reveal-delay: ${index * 100}ms`}
           >
             {/* Efecto de gradiente de fondo en hover */}
             <div class="absolute inset-0 bg-gradient-to-br from-primary-vibrant/5 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
             
             <div class="relative z-10">
               <div class="flex items-start justify-between mb-8">
                 <div class={`inline-flex h-14 w-14 items-center justify-center rounded-2xl border backdrop-blur-md transition-all duration-500 group-hover:scale-110 group-hover:rotate-3 ${isLarge ? 'border-primary-vibrant/30 bg-primary-vibrant/10 text-primary-vibrant shadow-lg shadow-primary-vibrant/20' : 'border-border-subtle bg-bg-card text-text-primary group-hover:border-primary-vibrant/50 group-hover:text-primary-vibrant'}`}>
                   <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={getServiceIcon(item.icon)} />
                   </svg>
                 </div>
                 
                 {isLarge && (
                   <div class="hidden sm:flex gap-2">
                     {item.tags?.map((tag: string) => (
                       <Badge variant="outline" className="flex items-center">
                         {BRAND_ICONS[tag] && <Fragment set:html={BRAND_ICONS[tag]} />}
                         {tag}
                       </Badge>
                     ))}
                   </div>
                 )}
               </div>

               <h3 class={`${isLarge ? 'text-3xl' : 'text-2xl'} font-bold text-text-primary mb-4 tracking-tight`}>{item.title}</h3>
               <p class="text-text-secondary leading-relaxed text-base">{item.description}</p>
             </div>

             {/* Elemento visual decorativo para la tarjeta grande */}
             {isLarge && (
               <div class="absolute -bottom-10 -right-10 w-64 h-64 bg-primary-vibrant/10 blur-3xl rounded-full pointer-events-none"></div>
             )}
           </Card>
         );
       })
     }

     {/* Tarjeta de Impacto Dominante (Digital Dashboard Style - Refined) */}
     <Card
       isPremium
       className="relative overflow-hidden group md:col-span-2 border-border-subtle shadow-2xl shadow-primary-vibrant/5"
       data-reveal
       style={`--reveal-delay: 300ms`}
     >
       {/* Capa de Ingeniería: Rejilla técnica ultra-sutil */}
       <div class="absolute inset-0 opacity-[0.02] bg-[url('data:image/svg+xml,%3Csvg width=%2240%22 height=%2240%22 viewBox=%220 0 40 40%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cpath d=%22M0 40 L40 40 L40 0%22 fill=%22none%22 stroke=%22%233b82f6%22 stroke-width=%221%22/%3E%3C/svg%3E')]"></div>
       
       <div class="relative z-20 flex flex-col lg:flex-row items-stretch gap-6 p-2">
         {/* SECCIÓN A: MÉTRICA HERO (Orientada a Autoridad) */}
         <div class="flex-1 flex flex-col justify-center p-8 bg-bg-default/50 rounded-2xl border border-border-subtle backdrop-blur-sm relative overflow-hidden">
           {/* Rayo de luz sutil en hover */}
           <div class="absolute top-0 -left-full w-full h-full bg-gradient-to-r from-transparent via-primary-vibrant/5 to-transparent skew-x-[-20deg] group-hover:left-full transition-all duration-1000 ease-in-out pointer-events-none"></div>

           <div class="flex items-center gap-3 mb-6">
             <div class="relative flex h-2 w-2">
               <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success opacity-75"></span>
               <span class="relative inline-flex rounded-full h-2 w-2 bg-success"></span>
             </div>
             <span class="text-[9px] font-black uppercase tracking-[0.2em] text-success">Node Active</span>
           </div>
           
           <h4 class="text-[10px] font-bold text-text-secondary uppercase tracking-widest mb-2">Impacto en el mercado</h4>
           <div class="flex items-baseline gap-2">
             <span class="text-8xl font-black tracking-tighter text-text-primary group-hover:text-primary-vibrant transition-colors duration-500">5+</span>
             <span class="text-xl font-bold text-primary-vibrant">activos</span>
           </div>
           <p class="text-sm text-text-secondary mt-4 leading-relaxed max-w-[200px]">
             Sistemas de alto rendimiento dominando sus categorías digitales.
           </p>
         </div>

         {/* SECCIÓN B: GRID DE OBJETIVOS TÉCNICOS (KPIs) */}
         <div class="flex-1 grid grid-cols-2 gap-4">
           {[
             { label: 'Performance', val: 'A+', desc: 'Core Web Vitals', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
             { label: 'Seguridad', val: '100%', desc: 'SSL + Edge Auth', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
             { label: 'Disponibilidad', val: '99.9%', desc: 'SLA Garantizado', icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' },
             { label: 'Carga', val: '<1s', desc: 'TTFB Optimizado', icon: 'M12 15v5m-3-4l3 3l3-3m-9-4v-1a5 5 0 0110 0v1m-10 0h10' },
           ].map((kpi) => (
             <div class="p-4 rounded-xl bg-bg-card border border-border-subtle group/kpi hover:border-primary-vibrant/30 transition-all duration-300">
               <div class="flex items-center gap-2 mb-2">
                  <svg class="w-3.5 h-3.5 text-primary-vibrant opacity-70 group-hover/kpi:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d={kpi.icon} />
                  </svg>
                  <span class="text-[9px] font-bold uppercase tracking-widest text-text-secondary">{kpi.label}</span>
               </div>
               <div class="text-xl font-black text-text-primary group-hover/kpi:text-primary-vibrant transition-colors">{kpi.val}</div>
               <div class="text-[9px] text-text-secondary/70 font-medium leading-none">{kpi.desc}</div>
             </div>
           ))}
         </div>
       </div>
     </Card>
   </div>
 </div>
 </section>

 <!-- Services Section -->
 <section class="py-20 md:py-32 relative" id="servicios">
 <div class="container mx-auto px-6">
 <SectionTitle
 badge="Nuestros Servicios"
 title="Construimos activos digitales de <span class='gradient-text'>alto rendimiento</span>"
 subtitle="No hacemos webs, construimos herramientas comerciales diseñadas para convertir visitas en ingresos."
 className="mb-16"
 />

 <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-4">
 {
 services.map((service, index) => {
 const media = SERVICE_HOME_MEDIA[service.id as keyof typeof SERVICE_HOME_MEDIA];
 return (
 <Card padding="none" data-reveal style={`--reveal-delay: ${index * 100}ms`}>
 <div class="aspect-video w-full overflow-hidden border-b border-border-subtle">
   <Image
     src={getOptimizedImage(media?.image)}
     alt={media?.alt ?? service.data.title}
     width={400}
     height={225}
     class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
   />
 </div>
 <div class="p-6">
 <Badge variant="accent-vibrant" className="mb-4">
 {media?.focus}
 </Badge>
 <h3 class="text-xl font-bold text-text-primary mb-3">{service.data.title}</h3>
 <p class="text-sm text-text-secondary leading-relaxed mb-6">
 {service.data.description}
 </p>
 <Button
 href={`/servicios/${service.id}`}
 variant="ghost"
 size="sm"
 className="p-0 hover:bg-transparent hover:text-primary"
 >
 Saber más &rarr;
 </Button>
 </div>
 </Card>
 );
 })
 }
 </div>
 </div>
 </section>

 <!-- Portfolio Section -->
 <section class="py-20 md:py-32 bg-bg-default">
 <div class="container mx-auto px-6">
 <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16">
 <SectionTitle
 align="left"
 badge="Portafolio"
 title="Resultados que <span class='gradient-text'>hablan por nosotros</span>"
 subtitle="Explora nuestras implementaciones reales en diversos sectores."
 className="max-w-2xl"
 />
 <Button href="/portafolio" variant="secondary">Ver todos los casos</Button>
 </div>

 <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
 {
 portfolioCases.slice(0, 3).map((item, index) => (
 <Card padding="none" data-reveal style={`--reveal-delay: ${index * 100}ms`}>
 <div class="aspect-video w-full overflow-hidden border-b border-border-subtle">
   <Image
     src={getOptimizedImage(item.data.image)}
     alt={item.data.title}
     width={600}
     height={337}
     class="h-full w-full object-cover"
   />
 </div>
 <div class="p-6">
 <div class="flex gap-2 mb-4">
 <Badge variant="outline">{PROJECT_TYPE_LABEL[item.data.projectType]}</Badge>
 </div>
 <h3 class="text-xl font-bold text-text-primary mb-2">{item.data.title}</h3>
 <p class="text-sm text-text-secondary line-clamp-2 mb-6">{item.data.summary}</p>
 <Button
 href={item.data.url}
 target="_blank"
 variant="outline"
 size="sm"
 className="w-full"
 >
 Visitar sitio
 </Button>
 </div>
 </Card>
 ))
 }
 </div>
 </div>
 </section>

 <!-- Process Section -->
 <section class="py-20 md:py-32 overflow-hidden">
   <div class="container mx-auto px-6">
     <SectionTitle
       badge="Metodología"
       title="Un proceso diseñado para la <span class='gradient-text'>velocidad y calidad</span>"
       subtitle="Mantenemos una comunicación fluida y un flujo de trabajo optimizado para cada etapa del desarrollo."
       className="mb-24"
     />
     <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4 relative">
       {/* Connection line for desktop */}
       <div class="hidden lg:block absolute top-1/2 left-0 w-full h-px bg-gradient-to-r from-transparent via-border-subtle to-transparent -translate-y-12 z-0"></div>

       {
         PROCESS_STEPS.map((step, index) => (
           <Card 
             padding="lg"
             className="relative z-10 group flex flex-col items-center text-center h-full" 
             data-reveal 
             style={`--reveal-delay: ${index * 150}ms`}
           >
             {/* Step number background bubble */}
             <div class="absolute -top-3 -right-3 w-12 h-12 rounded-full bg-bg-card border border-primary/20 shadow-md flex items-center justify-center text-lg font-black text-primary/80 group-hover:text-primary/80 group-hover:scale-110 transition-all duration-500 select-none shadow-sm">
               {step.id}
             </div>

             {/* Icon Container with Glass Effect */}
             <div class="mb-6 inline-flex h-14 w-14 items-center justify-center rounded-2xl backdrop-blur-md bg-primary/10 text-primary border border-primary/20 shadow-inner group-hover:bg-primary group-hover:text-white group-hover:rotate-6 group-hover:shadow-lg group-hover:shadow-primary/30 transition-all duration-500">
               <svg
                 xmlns="http://www.w3.org/2000/svg"
                 class="h-7 w-7"
                 fill="none"
                 viewBox="0 0 24 24"
                 stroke="currentColor"
               >
                 <path
                   stroke-linecap="round"
                   stroke-linejoin="round"
                   stroke-width="1.5"
                   d={getServiceIcon(step.icon)}
                 />
               </svg>
             </div>

             <h3 class="text-xl font-bold text-text-primary mb-3">{step.title}</h3>
             <p class="text-sm text-text-secondary leading-relaxed">{step.description}</p>
           </Card>
         ))
       }
     </div>
   </div>
 </section>

 <!-- Blog Section -->
 <section class="py-20 md:py-32 bg-bg-default">
 <div class="container mx-auto px-6">
 <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16">
 <SectionTitle
 align="left"
 badge="Blog"
 title="Insights para <span class='gradient-text'>crecer</span>"
 className="max-w-2xl"
 />
 <Button href="/blog" variant="secondary">Ir al blog</Button>
 </div>

 <div class="grid gap-8 md:grid-cols-3">
 {latestPosts.map((post) => (
 <a href={`/blog/${post.id}`} class="group">
 <Card padding="none" className="h-full">
 <div class="aspect-video w-full overflow-hidden border-b border-border-subtle">
   <Image
     src={getOptimizedImage(post.data.cover)}
     alt={post.data.title}
     width={500}
     height={280}
     class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
   />
 </div>
 <div class="p-6">
 <h3 class="text-lg font-bold text-text-primary mb-3 group-hover:text-primary-vibrant transition-colors">
 {post.data.title}
 </h3>
 <p class="text-sm text-text-secondary line-clamp-2">{post.data.excerpt}</p>
 </div>
 </Card>
 </a>
 ))}
 </div>
 </div>
 </section>

 <FAQ />

 <FinalCTA />
</MainLayout>
