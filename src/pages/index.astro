---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/sections/Hero.astro';
import { getCollection } from 'astro:content';

const services = (await getCollection('services'))
  .sort((a, b) => a.data.order - b.data.order);

const cases = (await getCollection('cases'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const portfolioOrder = [
  'posmart-saas',
  'inperu-landing',
  'turquesa-travel-multipage',
  'el-bambino-menu-digital',
  'zoi-beauty-ecommerce',
];

const portfolioCases = portfolioOrder
  .map((slug) => cases.find((item) => item.id === slug))
  .filter((item): item is (typeof cases)[number] => Boolean(item));

const latestPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const iconByService: Record<string, string> = {
  rocket: 'M5 12l5.5 5.5M4 20l5-1 9-9a4 4 0 10-5.66-5.66l-9 9-1 5z',
  layers: 'M12 3l9 4.5-9 4.5-9-4.5L12 3zm-9 9l9 4.5 9-4.5M3 16.5l9 4.5 9-4.5',
  cart: 'M3 4h2l1 10h11l2-7H6M9 20a1 1 0 100-2 1 1 0 000 2zm8 0a1 1 0 100-2 1 1 0 000 2z',
  spark: 'M12 3l2.5 5.5L20 11l-5.5 2.5L12 19l-2.5-5.5L4 11l5.5-2.5L12 3z',
};

const projectTypeLabel: Record<string, string> = {
  'saas': 'SaaS',
  'landing-page': 'Landing Page',
  'multipage': 'Multipage',
  'ecommerce': 'Ecommerce',
};

const processSteps = [
  {
    step: '01',
    title: 'Diagnóstico',
    description: 'Objetivos, público y propuesta de valor priorizada.',
    icon: 'M9 12h6m-6 4h3m-7 5h10a2 2 0 002-2V7a2 2 0 00-2-2H8l-2 2H4a2 2 0 00-2 2v10a2 2 0 002 2zm16-2l-3-3m0 0a4 4 0 10-5.66-5.66A4 4 0 0018 16z',
  },
  {
    step: '02',
    title: 'Arquitectura',
    description: 'Mapa de contenidos y flujo UX orientado a acción.',
    icon: 'M4 6h16M4 12h10M4 18h16M16 10l4 2-4 2V10z',
  },
  {
    step: '03',
    title: 'Diseño + Build',
    description: 'UI moderna, animaciones sutiles y rendimiento sólido.',
    icon: 'M7 7l10 10M17 7L7 17M3 12h2m14 0h2M12 3v2m0 14v2',
  },
  {
    step: '04',
    title: 'Optimización',
    description: 'Mejoras continuas basadas en comportamiento y datos.',
    icon: 'M4 16l4-4 3 3 5-6 4 4M4 20h16',
  },
];
---

<MainLayout
  title="Celeris Code | Landing, Multipage, Ecommerce y SaaS"
  description="Agencia digital especializada en landing pages, sitios multipage, ecommerce y plataformas SaaS con enfoque en UI/UX y conversión."
>
  <Hero />

  <section class="py-20">
    <div class="container mx-auto px-6">
      <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div class="max-w-3xl">
          <h2 class="section-title">Servicios diseñados para resultados reales</h2>
          <p class="section-subtitle mt-4">
            Basamos nuestra propuesta en estructura clara, navegación simple y decisiones visuales
            que aumentan confianza y conversión.
          </p>
        </div>
        <a href="/servicios" class="pill w-fit text-primary-vibrant">
          Ver todos los servicios
        </a>
      </div>

      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        {services.map((service) => (
          <article class="bento-card">
            <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-xl border border-primary-vibrant/35 bg-primary-vibrant/10 text-primary-vibrant">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={iconByService[service.data.icon ?? 'spark'] ?? iconByService.spark} />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white">{service.data.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-300">{service.data.description}</p>
            {service.data.highlight && <p class="mt-4 text-xs font-semibold text-primary-vibrant">{service.data.highlight}</p>}
            <a href={`/servicios/${service.id}`} class="mt-5 inline-flex text-sm font-semibold text-slate-100 hover:text-primary-vibrant">
              {service.data.ctaText} &rarr;
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="container mx-auto px-6">
      <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div class="max-w-3xl">
          <h2 class="section-title">Portafolio real: proyectos publicados</h2>
          <p class="section-subtitle mt-4">
            Estos son los proyectos reales de Celeris Code en SaaS, landing, multipage, menú digital y ecommerce.
          </p>
        </div>
        <a href="/portafolio" class="pill w-fit text-primary-vibrant">Explorar portafolio</a>
      </div>

      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {portfolioCases.map((item, index) => (
          <article class="bento-card overflow-hidden">
            <img src={item.data.image} alt={`Portada ${item.data.title}`} class="aspect-video w-full rounded-2xl border border-white/10 object-cover" loading="lazy" />
            <div class="mt-5">
              <div class="flex flex-wrap gap-2">
                <span class="pill">Proyecto #{index + 1}</span>
                <span class="pill">{projectTypeLabel[item.data.projectType] ?? item.data.projectType}</span>
              </div>
              <h3 class="mt-4 text-xl font-bold text-white">{item.data.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-300">{item.data.summary}</p>
              <p class="mt-3 text-xs font-semibold text-primary-vibrant">{item.data.client}</p>
              <a href={item.data.url} target="_blank" rel="noopener noreferrer" class="mt-4 inline-flex text-sm font-semibold text-primary-vibrant hover:text-sky-300">
                Visitar proyecto &rarr;
              </a>
            </div>
          </article>
        ))}
      </div>

      <div class="mt-8 grid gap-4 md:grid-cols-3">
        <article class="bento-card">
          <p class="text-technical">COBERTURA</p>
          <p class="mt-2 text-3xl font-black text-white">5 proyectos</p>
          <p class="mt-1 text-sm text-slate-300">Casos reales en producción y con links activos.</p>
        </article>
        <article class="bento-card">
          <p class="text-technical">TIPOLOGÍAS</p>
          <p class="mt-2 text-3xl font-black text-white">4 verticales</p>
          <p class="mt-1 text-sm text-slate-300">Landing Page, Multipage, Ecommerce y SaaS.</p>
        </article>
        <article class="bento-card">
          <p class="text-technical">FOCO</p>
          <p class="mt-2 text-3xl font-black text-white">UI/UX + negocio</p>
          <p class="mt-1 text-sm text-slate-300">Interfaces modernas alineadas a conversión y claridad.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="container mx-auto px-6">
      <div class="mx-auto max-w-4xl text-center">
        <h2 class="section-title">Nuestro proceso UX/UI + desarrollo</h2>
        <p class="section-subtitle mt-4">
          Estructura simple para avanzar con velocidad sin perder calidad.
        </p>
      </div>

      <div class="mx-auto mt-12 grid max-w-5xl gap-5 md:grid-cols-4">
        {processSteps.map((item) => (
          <article class="bento-card">
            <p class="text-technical">{item.step}</p>
            <div class="mt-3 flex justify-center">
              <span class="inline-flex h-14 w-14 items-center justify-center rounded-2xl border border-primary-vibrant/35 bg-gradient-to-r from-primary-vibrant/15 to-accent/15 text-primary-vibrant">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d={item.icon} />
                </svg>
              </span>
            </div>
            <h3 class="mt-3 text-lg font-bold text-white">{item.title}</h3>
            <p class="mt-2 text-sm text-slate-300">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="container mx-auto px-6">
      <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div class="max-w-3xl">
          <h2 class="section-title">Blog: diseño, UX y crecimiento digital</h2>
          <p class="section-subtitle mt-4">
            Ideas prácticas para mejorar la experiencia de tus usuarios y la conversión de tu negocio.
          </p>
        </div>
        <a href="/blog" class="pill w-fit text-primary-vibrant">Ir al blog</a>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {latestPosts.map((post) => (
          <article class="bento-card">
            <img src={post.data.cover} alt={`Portada ${post.data.title}`} class="aspect-video w-full rounded-2xl border border-white/10 object-cover" loading="lazy" />
            <h3 class="mt-5 text-xl font-bold text-white">{post.data.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-300">{post.data.excerpt}</p>
            <a href={`/blog/${post.id}`} class="mt-4 inline-flex text-sm font-semibold text-primary-vibrant hover:text-sky-300">
              Leer artículo &rarr;
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="pb-12 pt-6">
    <div class="container mx-auto px-6">
      <div class="bento-card-premium mx-auto max-w-5xl p-8 text-center md:p-12">
        <h2 class="text-3xl font-extrabold text-white md:text-5xl">
          ¿Listo para acelerar tu presencia digital?
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-slate-300">
          Te ayudamos a definir, diseñar y construir una experiencia web moderna enfocada en resultados.
        </p>
        <a
          href="/contacto"
          class="mt-8 inline-flex rounded-xl bg-gradient-to-r from-primary-vibrant to-accent px-8 py-4 font-bold text-white transition-transform hover:scale-[1.02]"
        >
          Impulsa tu Proyecto
        </a>
      </div>
    </div>
  </section>
</MainLayout>
